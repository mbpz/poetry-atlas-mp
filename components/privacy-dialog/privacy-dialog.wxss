/* 隐私协议弹框 — 全屏阻断 */
.privacy-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(246, 241, 228, 0.97);
  z-index: 9999;
  display: flex; align-items: center; justify-content: center;
}
.privacy-card {
  width: 620rpx; background: var(--ink-surface);
  border-radius: 28rpx; padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid var(--ink-line);
  display: flex; flex-direction: column; align-items: center;
}
.privacy-logo {
  width: 112rpx; height: 112rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--cinnabar), var(--gold));
  color: #fff; font-size: 52rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
}
.privacy-title {
  font-size: 34rpx; font-weight: 600;
  color: var(--paper-text); margin-bottom: 28rpx;
  letter-spacing: 0.08em;
}
.privacy-body {
  width: 100%; max-height: 300rpx; margin-bottom: 36rpx;
}
.privacy-text {
  font-size: 28rpx; color: var(--paper-text); line-height: 1.9;
  letter-spacing: 0.04em;
}
.privacy-btns { display: flex; gap: 20rpx; width: 100%; }
.privacy-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  text-align: center; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 600;
}
.privacy-btn.disagree {
  background: var(--ink-surface-2);
  color: var(--paper-text-2);
  border: 1rpx solid var(--ink-line);
}
.privacy-btn.agree {
  background: var(--cinnabar); color: #fff;
}
.privacy-btn:active { transform: scale(0.97); }
