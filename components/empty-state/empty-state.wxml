<view class="empty-state">
  <image wx:if="{{iconSrc}}" class="empty-icon-img" src="{{iconSrc}}" mode="aspectFit" aria-label="{{title}}" />
  <view wx:else class="empty-icon">{{icon}}</view>
  <view class="empty-title">{{title}}</view>
  <view wx:if="{{tip}}" class="empty-tip">{{tip}}</view>
  <view wx:if="{{showBtn}}" class="empty-btn" bindtap="onBtn">{{btnText}}</view>
</view>
