.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-icon-img {
  display: block;
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 24rpx;
  opacity: 0.5;
}
.empty-title {
  font-size: 30rpx;
  color: var(--paper-text-2);
  margin-bottom: 12rpx;
  font-weight: 500;
}
.empty-tip {
  font-size: 24rpx;
  color: var(--paper-text-2);
  line-height: 1.6;
}
.empty-btn {
  display: inline-block;
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: var(--cinnabar);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
}
