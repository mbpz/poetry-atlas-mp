<!-- 评论面板（inline，帖子底部）-->
<view class="cp">
  <!-- 列表 -->
  <view class="cp-list" wx:if="{{list.length}}">
    <view
      wx:for="{{list}}"
      wx:key="_id"
      class="cp-item"
    >
      <view class="cp-body">
        <text class="cp-nick">{{item.nickname || '诗友'}}</text>
        <text class="cp-content">{{item.content}}</text>
      </view>
      <view
        wx:if="{{item.owner}}"
        class="cp-remove"
        data-id="{{item._id}}"
        catchtap="onRemove"
      >删除</view>
    </view>
  </view>
  <view wx:elif="{{loading}}" class="cp-status">载入中…</view>
  <view wx:elif="{{loaded && !list.length}}" class="cp-status">暂无评论，来抢沙发</view>

  <!-- 输入框 -->
  <view class="cp-input-row">
    <input
      class="cp-input"
      placeholder="写评论…"
      placeholder-class="cp-placeholder"
      value="{{draft}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSend"
      cursor-spacing="16"
    />
    <view class="cp-send {{draft.trim() ? '' : 'cp-send-disabled'}}" bindtap="onSend">发送</view>
  </view>
</view>
