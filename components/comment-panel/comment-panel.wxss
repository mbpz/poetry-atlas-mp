/* 评论面板 — 宣纸淡墨 */
.cp { margin-top: 16rpx; border-top: 1rpx dashed var(--ink-line); padding-top: 16rpx; }

.cp-list { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 12rpx; }
.cp-item { display: flex; align-items: flex-start; justify-content: space-between; gap: 12rpx; }
.cp-body { flex: 1; min-width: 0; background: var(--ink-bg); border-radius: 10rpx; padding: 10rpx 16rpx; }
.cp-nick { font-size: 24rpx; color: var(--gold); margin-right: 12rpx; font-weight: 600; }
.cp-content { font-size: 26rpx; color: var(--paper-text); line-height: 1.7; }
.cp-remove {
  font-size: 24rpx; color: var(--cinnabar);
  padding: 10rpx 4rpx; flex-shrink: 0;
}
.cp-status { font-size: 24rpx; color: var(--paper-text-2); text-align: center; padding: 16rpx 0; }

.cp-input-row { display: flex; align-items: center; gap: 12rpx; }
.cp-input {
  flex: 1;
  background: var(--ink-bg);
  border: 1rpx solid var(--ink-line);
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: var(--paper-text);
}
.cp-placeholder { color: var(--paper-text-2); }
.cp-send {
  font-size: 26rpx; color: #fff; background: var(--cinnabar);
  padding: 12rpx 28rpx; border-radius: 30rpx;
  letter-spacing: 0.06em; flex-shrink: 0;
}
.cp-send-disabled { opacity: 0.4; }
