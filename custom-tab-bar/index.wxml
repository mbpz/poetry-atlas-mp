<!-- TabBar — 沉浸水墨风
  [🗺地图] [🔍发现] [📜朝代] [♡收藏]   +  🔎(右下跳转搜索页)
  注：搜索珠直接跳转搜索 Tab 页（navigateTo 无法打开 tab 页）
-->
<view class="tab-bar">
  <view class="tab-nav">
    <view
      wx:for="{{tabs}}" wx:key="key"
      class="tab-item {{active === item.key ? 'active' : ''}}"
      data-key="{{item.key}}" bindtap="switchTab" catchtouchstart="noop"
    >
      <image src="{{ico[item.icon]}}" class="tab-ico" mode="aspectFit"></image>
      <text class="tab-label">{{item.label}}</text>
      <view wx:if="{{active === item.key}}" class="tab-dot"></view>
    </view>
  </view>
</view>

<!-- 右下角浮动搜索珠：直接跳到搜索 Tab（该页有 autofocus 搜索框 + 热词）-->
<view class="search-fab" bindtap="enterSearch" catchtouchstart="noop">
  <image src="{{ico.search}}" class="fab-ico" mode="aspectFit"></image>
</view>
