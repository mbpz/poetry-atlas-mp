<view class="tab-bar">
  <!-- 顶部凸起弧线（选中项）-->
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-arc {{selected === index ? 'show' : ''}}"
    style="left: {{index * 25}}%"
  ></view>

  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-url="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="{{selected === index ? item.activeIconUrl : item.iconUrl}}" mode="aspectFit"></image>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
