<!-- 自定义 tabBar：必须用 cover-view，否则 map 等原生组件会挡住点击
     官方文档：https://developers.weixin.qq.com/miniprogram/dev/framework/ability/custom-tabbar.html -->
<cover-view class="tab-bar">
  <cover-view class="tab-nav">
    <cover-view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{active === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >
      <cover-view class="tab-label {{active === item.key ? 'active' : ''}}">{{item.label}}</cover-view>
      <cover-view wx:if="{{active === item.key}}" class="tab-dot"></cover-view>
    </cover-view>
  </cover-view>
</cover-view>

<cover-view class="search-fab" bindtap="enterSearch">
  <cover-view class="fab-text">搜</cover-view>
</cover-view>
