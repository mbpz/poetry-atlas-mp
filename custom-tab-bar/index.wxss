/* ============================================================
   TabBar — 宣纸淡墨
   底部 4 分米白胶囊 + 文字标签 + 右下搜索珠
   ============================================================ */

.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 128rpx;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
  pointer-events: none;
}

.tab-bar > view { pointer-events: auto; }

/* ===== 主导航 ===== */
.tab-nav {
  position: relative;
  display: flex;
  flex-direction: row;
  width: 100%;
  height: 100%;
  padding: 0 24rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 100%;
  position: relative;
}
.tab-item:active { transform: scale(0.9); }

.tab-ico {
  width: 44rpx; height: 44rpx;
  opacity: 0.5;
  transition: opacity 0.2s;
}
.tab-item.active .tab-ico { opacity: 1; }

.tab-label {
  font-size: 20rpx;
  color: var(--paper-text-2);
  letter-spacing: 0.12em;
  transition: color 0.2s;
}
.tab-item.active .tab-label {
  color: var(--cinnabar);
}

/* 激活指示 — 顶部朱砂小点 */
.tab-dot {
  position: absolute;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--cinnabar);
  box-shadow: 0 0 8rpx rgba(158, 43, 35, 0.6);
}

/* ===== 右下角浮动搜索珠 ===== */
.search-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(148rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(158, 43, 35, 0.15), rgba(168, 136, 72, 0.15));
  border: 1rpx solid rgba(168, 136, 72, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  box-shadow: 0 4rpx 20rpx rgba(120, 100, 70, 0.15);
  transition: transform 0.2s;
}
.search-fab:active { transform: scale(0.88); }
.fab-ico { width: 44rpx; height: 44rpx; }
