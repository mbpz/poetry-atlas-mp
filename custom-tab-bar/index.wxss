/* ============================================================
   TabBar — Editorial 文脉风
   宋版书美学 · Songti SC · 朱砂 #8b1a1a · 宣纸 #f5f0e8
   ============================================================ */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 宣纸底 — 带纹理 */
.tab-bar-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.6) 0%, transparent 70%),
    linear-gradient(180deg, #f7f4ed 0%, #f0ebe0 100%);
  border-top: 1rpx solid rgba(139, 26, 26, 0.08);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 5 等分 flex */
.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 2rpx;
  transition: transform 0.15s ease;
}
.tab-item:active { transform: scale(0.92); }

/* 顶部朱砂横线 — 仅选中态 */
.tab-indicator {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%) scaleX(0);
  width: 40rpx;
  height: 4rpx;
  background: #8b1a1a;
  border-radius: 2rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.tab-item.active .tab-indicator {
  transform: translateX(-50%) scaleX(1);
}

/* 文字标签 — Songti SC 宋体 */
.tab-label {
  font-size: 20rpx;
  color: #999;
  letter-spacing: 0.06em;
  line-height: 1;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  transition: all 0.25s;
}
.tab-item.active .tab-label {
  color: #8b1a1a;
  font-weight: 600;
}

/* 图标 */
.tab-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.tab-icon image {
  width: 40rpx;
  height: 40rpx;
}
.tab-item.active .tab-icon {
  transform: scale(1.12);
}
