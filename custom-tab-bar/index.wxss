/* ============================================================
   TabBar — Substack 液态玻璃风（iOS glassmorphism）
   状态 A: [🗺][📜][♡][🔎]  ||  🔎(右侧大按钮)
   状态 B: [⌂] [🔍 search input..........]
   ============================================================ */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
  overflow: hidden;
}

/* 玻璃底（半透明+模糊）*/
.glass-bg {
  position: absolute;
  inset: 0;
  background: rgba(247, 244, 237, 0.82);
  backdrop-filter: blur(40rpx) saturate(1.2);
  -webkit-backdrop-filter: blur(40rpx) saturate(1.2);
  border-top: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* ===== 状态 A: 主导航 ===== */
.tab-nav {
  position: relative;
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 24rpx;
}

/* 左侧多球组 */
.pill-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 中间分隔（把右侧搜索珠推到右边）*/
.spacer { flex: 1; }

/* 单个玻璃球 */
.pill-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.pill-btn:active { transform: scale(0.88); }
.pill-btn.active {
  background: rgba(139, 26, 26, 0.12);
  border-color: rgba(139, 26, 26, 0.2);
  box-shadow:
    0 2rpx 12rpx rgba(139, 26, 26, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}
.pill-ico { width: 44rpx; height: 44rpx; }

/* 右侧独立搜索珠 */
.pill-right {
  background: rgba(139, 26, 26, 0.08);
  border-color: rgba(139, 26, 26, 0.15);
}

/* ===== 状态 B: 搜索模式 ===== */
.tab-search {
  position: relative;
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 24rpx;
  gap: 16rpx;
  animation: slideIn 0.3s ease;
}
@keyframes slideIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.search-back {
  flex-shrink: 0;
}

.search-input-wrap {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  box-shadow: inset 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}
.search-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #2c2c2c;
}
.search-ph { color: #b0b0b0; }
