/* cover-view 支持的样式有限：不用 backdrop-filter / 复杂阴影 / 百分比子项坑 */

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
  background-color: #f6f1e4;
  border-top: 1rpx solid #e2d9c6;
}

.tab-nav {
  display: flex;
  flex-direction: row;
  width: 750rpx;
  height: 112rpx;
}

.tab-item {
  width: 150rpx;
  flex-grow: 0;
  flex-shrink: 0;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-label {
  font-size: 26rpx;
  color: #9a9386;
  letter-spacing: 0.08em;
  line-height: 1.2;
}

.tab-label.active {
  color: #9e2b23;
  font-weight: 600;
}

.tab-dot {
  position: absolute;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #9e2b23;
}

.search-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: #9e2b23;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
}

.fab-text {
  color: #fffef9;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  line-height: 1;
}
