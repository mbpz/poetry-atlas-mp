/* ===== 收藏页 — 沉浸水墨 ===== */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom)); }

.fav-card {
  margin: 16rpx 0; padding: 28rpx 32rpx;
  display: flex; align-items: flex-start;
  transition: transform 0.12s;
}
.fav-content { flex: 1; }
.fav-title { font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; color: var(--paper-text); }
.fav-sub { display: flex; align-items: center; gap: 12rpx; font-size: 24rpx; color: var(--paper-text-2); margin-bottom: 12rpx; }
.fav-line { font-size: 26rpx; line-height: 1.9; color: var(--paper-text-2); }

/* 删除按钮：48x48 大目标 + 按下反馈 */
.fav-del {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: var(--ink-surface-2); margin-left: 16rpx; flex-shrink: 0;
  border: 1rpx solid var(--ink-line);
  transition: transform 0.12s, background 0.15s;
}
.fav-del:active { transform: scale(0.85); background: rgba(158, 43, 35, 0.12); }
.fav-del-ico { font-size: 36rpx; color: var(--paper-text-2); }
.fav-del:active .fav-del-ico { color: var(--cinnabar); }
