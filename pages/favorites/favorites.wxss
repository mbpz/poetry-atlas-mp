.page { min-height: 100vh; padding: 24rpx 24rpx 60rpx; }

.fav-list {  }
.fav-card {
  margin: 16rpx 0; padding: 28rpx 32rpx;
  display: flex; align-items: flex-start;
}
.fav-content { flex: 1; }
.fav-title { font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.fav-sub { display: flex; align-items: center; gap: 12rpx; font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.fav-lines {  }
.fav-line { font-size: 26rpx; line-height: 1.8; color: #5a5a5a; }

.fav-del {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #ccc; margin-left: 16rpx;
}

.empty-block { text-align: center; padding: 160rpx 40rpx; }
.empty-icon { font-size: 80rpx; color: #ddd; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.empty-tip { font-size: 24rpx; color: #bbb; }
