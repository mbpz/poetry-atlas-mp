<!-- 朝代浏览页 — 时间轴展开 -->
<scroll-view
  class="page"
  scroll-y
  enhanced
  show-scrollbar="{{false}}"
  refresher-enabled
  lower-threshold="100"
  refresher-triggered="{{refreshing}}"
  bindrefresherrefresh="onRefresh"
  bindscrolltolower="onLoadMore"
>
  <view class="page-inner">
    <view class="page-desc">按朝代浏览诗词，下拉刷新，上滑加载</view>

    <view class="timeline">
      <view
        wx:for="{{dynasties}}"
        wx:key="name"
        class="timeline-item {{expanded === item.name ? 'is-active' : ''}}"
        data-dynasty="{{item.name}}"
        bindtap="onToggle"
      >
        <view class="timeline-node">
          <view class="node-dot"></view>
          <view class="node-line"></view>
        </view>
        <view class="timeline-content card spring-card">
          <view class="dynasty-header">
            <view class="dynasty-name">{{item.name}}</view>
            <view class="dynasty-period">{{item.start_year}} ~ {{item.end_year}}</view>
            <view class="dynasty-count">{{item.poem_count}} 首</view>
          </view>

          <!-- 展开诗词列表（直接渲染，由外层 scroll-view 统一滚动；内层已弃用 nested scroll 避免滚动劫持）-->
          <view wx:if="{{expanded === item.name}}" class="dynasty-poems.show">
            <view
              wx:for="{{poemsByDynasty[item.name]}}"
              wx:for-item="poem"
              wx:key="_id"
              class="dynasty-poem spring-btn"
              data-poem="{{poem}}"
              bindtap="onTapPoem"
            >
              <view class="dynasty-poem-title">{{poem.title}}</view>
              <view class="dynasty-poem-author">{{poem.dynasty}} · {{poem.author}}</view>
            </view>
            <view wx:if="{{loadingMoreDynasty === item.name}}" class="load-more">载入中…</view>
            <view wx:elif="{{hasMoreDynasty[item.name] && poemsByDynasty[item.name].length >= pageSize}}" class="load-more" bindtap="onLoadMoreForDynasty" data-dynasty="{{item.name}}">点击加载更多</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="list-loading">载入更多朝代…</view>
    <view wx:if="{{!hasMoreDynasties && dynasties.length > 0}}" class="list-end">— 已显示全部朝代 —</view>
  </view>
</scroll-view>

<view wx:if="{{loading && !dynasties.length}}" class="empty">载入中…</view>
