/* ===== 朝代页 — 沉浸水墨 ===== */
.page { width: 100%; height: 100vh; overflow-y: scroll; }
.page-inner { padding: 32rpx 28rpx calc(140rpx + env(safe-area-inset-bottom)); }

.page-desc {
  font-size: 24rpx; color: var(--paper-text-2);
  text-align: center; padding: 16rpx 0 28rpx; letter-spacing: 0.05em;
}

.timeline { position: relative; }
.timeline-item { display: flex; margin-bottom: 12rpx; }
.timeline-node {
  width: 72rpx; display: flex; flex-direction: column; align-items: center; flex-shrink: 0;
  margin-right: 20rpx;
}
.node-dot {
  width: 28rpx; height: 28rpx; border-radius: 50%;
  background: var(--ink-surface); margin-top: 40rpx; border: 2rpx solid var(--ink-line);
  transition: transform 0.25s, background 0.25s, border-color 0.25s;
  z-index: 1; position: relative;
}
.timeline-item.is-active .node-dot {
  transform: scale(1.35); background: var(--cinnabar); border-color: var(--cinnabar);
  box-shadow: 0 0 0 8rpx rgba(158, 43, 35, 0.18);
}
.node-line { flex: 1; width: 2rpx; background: var(--ink-line); margin-top: 8rpx; }

.timeline-content { flex: 1; padding: 32rpx 36rpx; }
.dynasty-header { display: flex; align-items: baseline; gap: 16rpx; flex-wrap: wrap; }
.dynasty-name { font-size: 40rpx; font-weight: 700; color: var(--paper-text); letter-spacing: 0.08em; }
.dynasty-period { font-size: 22rpx; color: var(--paper-text-2); }
.dynasty-count {
  margin-left: auto; font-size: 22rpx; color: var(--cinnabar);
  background: rgba(158, 43, 35, 0.08); padding: 4rpx 16rpx; border-radius: 20rpx;
  border: 1rpx solid rgba(158, 43, 35, 0.2);
}

/* 展开诗词列表（独立 scroll-view）*/
.dynasty-poems {
  display: none;
  border-top: 1rpx dashed var(--ink-line); padding-top: 16rpx;
}
.dynasty-poems.show { display: block; }
.dynasty-poems-scroll { max-height: 60vh; }

.dynasty-poem {
  padding: 22rpx 4rpx; border-bottom: 1rpx solid var(--ink-line);
  transition: background 0.15s;
}
.dynasty-poem:last-child { border-bottom: none; }
.dynasty-poem:active { background: rgba(158, 43, 35, 0.04); }
.dynasty-poem-title { font-size: 28rpx; color: var(--paper-text); margin-bottom: 4rpx; }
.dynasty-poem-author { font-size: 24rpx; color: var(--gold); }

.load-more {
  text-align: center; padding: 24rpx 0; font-size: 24rpx; color: var(--gold);
}
.list-loading, .list-end { text-align: center; padding: 32rpx 0; color: var(--paper-text-2); font-size: 24rpx; }
