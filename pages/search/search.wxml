<!-- 发现/搜索页 -->
<view class="page">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <image class="search-icon" src="/tab-bar-icons/search.svg" mode="aspectFit" aria-label="搜索" />
      <input
        class="search-input"
        placeholder="搜索诗词、作者、地点"
        value="{{keyword}}"
        bindinput="onInput"
        confirm-type="search"
        aria-label="搜索诗词、作者或地点"
        focus
      />
      <view wx:if="{{keyword}}" class="clear-btn" bindtap="onClear">×</view>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view wx:if="{{!searched}}" class="hot-section">
    <view class="section-title">热门搜索</view>
    <view class="hot-tags">
      <view
        wx:for="{{hotKeywords}}"
        wx:key="*this"
        class="hot-tag"
        data-keyword="{{item}}"
        bindtap="onTapHot"
      >{{item}}</view>
    </view>
  </view>

  <!-- 加载态骨架 -->
  <view wx:if="{{searched && loading}}" class="result-list">
    <skeleton rows="4" />
    <skeleton rows="3" avatar />
  </view>

  <!-- 结果 -->
  <view wx:if="{{searched && !loading}}">
    <view wx:if="{{poems.length || authors.length || places.length}}">
      <!-- 结果 Tab（可横滑）-->
      <scroll-view scroll-x class="result-tabs" enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{tabs}}"
          wx:key="key"
          class="result-tab {{activeTab === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSelectTab"
        >{{item.label}}</view>
      </scroll-view>

      <!-- 诗词结果 -->
      <view class="result-list">
        <view wx:if="{{(activeTab === 'all' || activeTab === 'poem') && poems.length}}">
          <view class="group-title">诗词 ({{poems.length}})</view>
          <view
            wx:for="{{poems}}"
            wx:key="_id"
            class="card result-card"
            data-poem="{{item}}"
            bindtap="onTapPoem"
          >
            <view class="result-title">{{item.title}}</view>
            <view class="result-sub">
              <text class="dynasty-tag">{{item.dynasty}}</text>
              <text>{{item.author}}</text>
            </view>
            <view wx:if="{{item.content}}" class="result-preview">{{item.content}}</view>
          </view>
        </view>

        <!-- 作者结果 -->
        <view wx:if="{{(activeTab === 'all' || activeTab === 'author') && authors.length}}">
          <view class="group-title">作者 ({{authors.length}})</view>
          <view
            wx:for="{{authors}}"
            wx:key="_id"
            class="card result-card"
            data-author="{{item}}"
            bindtap="onTapAuthor"
          >
            <view class="result-title">{{item.name}}</view>
            <view class="result-sub">{{item.dynasty}} · {{item.poem_count}} 首</view>
          </view>
        </view>

        <!-- 地点结果 -->
        <view wx:if="{{(activeTab === 'all' || activeTab === 'place') && places.length}}">
          <view class="group-title">地点 ({{places.length}})</view>
          <view
            wx:for="{{places}}"
            wx:key="_id"
            class="card result-card"
            data-place="{{item}}"
            bindtap="onTapPlace"
          >
            <view class="result-title">{{item.name}}</view>
            <view class="result-sub">{{item.type}} · {{item.poem_count}} 首诗词</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <empty-state
      wx:else
      iconSrc="/tab-bar-icons/search.svg"
      title="未找到「{{keyword}}」"
      tip="换个词试试，或浏览地图发现更多"
    />
  </view>
</view>
