<!-- 社区 Feed — 宣纸淡墨 -->
<view class="page">

  <!-- Banner -->
  <view class="banner card">
    <view class="banner-title">诗词社区</view>
    <view class="banner-sub">以诗会友 · 字字珠玑</view>
    <view class="banner-stats">
      <view class="banner-stat"><text class="banner-num">{{bannerUsers}}</text><text class="bannerlbl">诗友</text></view>
      <view class="banner-divider"></view>
      <view class="banner-stat"><text class="banner-num">{{bannerPosts}}</text><text class="banner-lbl">动态</text></view>
    </view>
  </view>

  <!-- 骨架屏 -->
  <block wx:if="{{loading && !posts.length}}">
    <skeleton rows="2" avatar="{{true}}" />
    <skeleton rows="3" avatar="{{true}}" />
    <skeleton rows="2" avatar="{{true}}" />
  </block>

  <!-- 空状态 -->
  <block wx:elif="{{!loading && !posts.length}}">
    <empty-state icon="📜" title="还没有动态" tip="做第一个分享诗句感悟的人吧" showBtn="{{true}}" btnText="写一首" bind:tap="onOpenPublish" />
  </block>

  <!-- Feed 列表 -->
  <view class="feed" wx:else>
    <view
      wx:for="{{posts}}"
      wx:key="_id"
      class="post card spring-card"
    >
      <!-- 头部：头像 + 昵称 + 关注/删除 -->
      <view class="post-head">
        <view class="post-avatar">
          <image wx:if="{{item.avatar_url}}" src="{{item.avatar_url}}" class="post-avatar-img" mode="aspectFill" />
          <text wx:else class="post-avatar-txt">{{item.nickname[0] || '诗'}}</text>
        </view>
        <view class="post-head-meta">
          <view class="post-nick">{{item.nickname || '诗友'}}</view>
          <view class="post-time">{{item.timeText}}</view>
        </view>
        <view class="post-head-actions">
          <view
            wx:if="{{item.openid && item.openid !== openid}}"
            class="follow-btn spring-btn"
            data-openid="{{item.openid}}"
            catchtap="onToggleFollow"
          >＋ 关注</view>
          <view
            wx:elif="{{item.owner}}"
            class="post-delete"
            data-id="{{item._id}}"
            catchtap="onRemovePost"
          >删除</view>
        </view>
      </view>

      <!-- 关联诗词标签 -->
      <view
        wx:if="{{item.poem_id}}"
        class="post-poem-tag spring-btn"
        data-poem="{{item.poem_id}}"
        catchtap="onTapPoem"
      >
        <text class="tag-ico">📜</text>
        <text class="tag-txt">{{item.author_name ? item.author_name + ' · ' : ''}}引用诗词</text>
      </view>

      <!-- 文字内容 -->
      <view class="post-content">{{item.content}}</view>

      <!-- 图片网格 -->
      <view wx:if="{{item.images.length}}" class="post-images img-grid-{{item.images.length}}">
        <view
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          class="post-img-cell"
        >
          <image
            src="{{img}}"
            class="post-img {{item.images.length === 1 ? 'post-img-single' : ''}}"
            mode="aspectFill"
            data-post="{{item}}"
            data-index="{{index}}"
            bindtap="onPreviewImage"
          />
        </view>
      </view>

      <!-- 互动条：点赞 + 评论 -->
      <view class="post-actions">
        <view class="act-item {{item.liked ? 'liked' : ''}}" data-id="{{item._id}}" bindtap="onToggleLike">
          <text class="act-ico">{{item.liked ? '❤️' : '♡'}}</text>
          <text class="act-num">{{item.likes_count || ''}}</text>
        </view>
        <view class="act-item" data-id="{{item._id}}" bindtap="onToggleComments">
          <text class="act-ico">💬</text>
          <text class="act-num">{{item.comments_count || ''}}</text>
        </view>
      </view>

      <!-- 评论面板（inline，展开）-->
      <comment-panel
        wx:if="{{expandedComment === item._id}}"
        post-id="{{item._id}}"
        comments="{{item.comments}}"
        bind:change="onCommentsChange"
      />
    </view>

    <!-- 底部加载更多 -->
    <view class="feed-footer" wx:if="{{!noMore && posts.length}}">
      <text wx:if="{{loadingMore}}">载入中…</text>
    </view>
    <view class="feed-footer feed-footer-end" wx:if="{{noMore && posts.length}}">— 已经到底了 —</view>
  </view>
</view>

<!-- FAB -->
<view class="fab" bindtap="onOpenPublish" catchtouchstart="noop">
  <text class="fab-ico">✎</text>
  <text class="fab-txt">写一写</text>
</view>
