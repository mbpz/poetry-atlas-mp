/* 社区 Feed — 宣纸淡墨 */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(200rpx + env(safe-area-inset-bottom)); }

/* Banner */
.banner {
  padding: 40rpx 36rpx; margin-bottom: 24rpx; text-align: center;
  background: linear-gradient(135deg, rgba(158,43,35,0.06), rgba(168,136,72,0.06));
}
.banner-title { font-size: 44rpx; font-weight: 700; color: var(--paper-text); letter-spacing: 0.12em; }
.banner-sub { font-size: 24rpx; color: var(--paper-text-2); margin-top: 8rpx; letter-spacing: 0.1em; }
.banner-stats { display: flex; align-items: center; justify-content:center; gap:0; margin-top: 24rpx; }
.banner-stat { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.banner-num { font-size: 40rpx; font-weight: 700; color: var(--cinnabar); }
.banner-lbl { font-size: 22rpx; color: var(--paper-text-2); letter-spacing: 0.1em; }
.banner-divider { width: 1rpx; height: 60rpx; background: var(--ink-line); }

/* Feed */
.feed { display: flex; flex-direction: column; gap: 24rpx; }
.post { padding: 28rpx 28rpx 24rpx; }

/* 头部 */
.post-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.post-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: var(--ink-surface-2); overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  border: 1rpx solid var(--ink-line); flex-shrink: 0;
}
.post-avatar-img { width: 100%; height: 100%; }
.post-avatar-txt { font-size: 32rpx; color: var(--gold); font-weight: 600; }
.post-head-meta { flex: 1; min-width: 0; }
.post-nick { font-size: 28rpx; color: var(--paper-text); font-weight: 600; }
.post-time { font-size: 22rpx; color: var(--paper-text-2); margin-top: 2rpx; }
.post-head-actions { flex-shrink: 0; }
.follow-btn {
  font-size: 24rpx; color: #fff; background: var(--cinnabar);
  padding: 8rpx 24rpx; border-radius: 30rpx; letter-spacing: 0.06em;
}
.post-delete { font-size: 24rpx; color: var(--paper-text-2); padding: 8rpx 12rpx; }

/* 关联诗词标签 */
.post-poem-tag {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 8rpx 20rpx; margin-bottom: 16rpx;
  background: rgba(168,136,72,0.1); border: 1rpx solid rgba(168,136,72,0.3);
  border-radius: 30rpx;
}
.tag-ico { font-size: 24rpx; }
.tag-txt { font-size: 24rpx; color: var(--gold); }

/* 内容 */
.post-content {
  font-size: 30rpx; color: var(--paper-text); line-height: 1.9;
  white-space: pre-wrap; word-break: break-all; margin-bottom: 16rpx;
  letter-spacing: 0.03em;
}

/* 图片网格 */
.post-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; }
.post-img-cell { border-radius: 10rpx; overflow: hidden; background: var(--ink-surface-2); }
.post-img { display: block; }
/* 1 张: 宽限定 */
.img-grid-1 .post-img-cell { width: 100%; }
.img-grid-1 .post-img-single { width: 100%; max-height: 600rpx; }
/* 2/4: 2 列 */
.img-grid-2 .post-img-cell, .img-grid-4 .post-img-cell { width: calc((100% - 8rpx) / 2); aspect-ratio: 1/1; }
.img-grid-2 .post-img, .img-grid-4 .post-img { width: 100%; height: 100%; }
/* 3/5/6/7/8/9: 3 列 */
.img-grid-3 .post-img-cell, .img-grid-5 .post-img-cell, .img-grid-6 .post-img-cell,
.img-grid-7 .post-img-cell, .img-grid-8 .post-img-cell, .img-grid-9 .post-img-cell {
  width: calc((100% - 16rpx) / 3); aspect-ratio: 1/1;
}
.img-grid-3 .post-img, .img-grid-5 .post-img, .img-grid-6 .post-img,
.img-grid-7 .post-img, .img-grid-8 .post-img, .img-grid-9 .post-img { width: 100%; height: 100%; }

/* 互动条 */
.post-actions { display: flex; gap: 32rpx; align-items: center; padding-top: 16rpx; border-top: 1rpx dashed var(--ink-line); }
.act-item { display: flex; align-items: center; gap: 8rpx; }
.act-ico { font-size: 32rpx; }
.act-num { font-size: 24rpx; color: var(--paper-text-2); }
.act-item.liked .act-num { color: var(--cinnabar); }

/* 底部 */
.feed-footer { text-align: center; font-size: 24rpx; color: var(--paper-text-2); padding: 24rpx 0; }
.feed-footer-end { letter-spacing: 0.1em; }

/* FAB */
.fab {
  position: fixed; right: 32rpx; bottom: calc(160rpx + env(safe-area-inset-bottom));
  display: flex; align-items: center; gap: 8rpx;
  padding: 16rpx 32rpx; border-radius: 50rpx;
  background: linear-gradient(135deg, var(--cinnabar), var(--cinnabar-soft));
  color: #fff; z-index: 90;
  box-shadow: 0 8rpx 24rpx rgba(158,43,35,0.3);
  transition: transform 0.15s;
}
.fab:active { transform: scale(0.9); }
.fab-ico { font-size: 28rpx; }
.fab-txt { font-size: 26rpx; letter-spacing: 0.08em; }
