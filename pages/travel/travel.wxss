.page { min-height: 100vh; padding: 24rpx 24rpx 60rpx; }

.travel-hero { padding: 40rpx 36rpx; margin-bottom: 24rpx; }
.travel-name { font-size: 40rpx; font-weight: 700; margin-bottom: 16rpx; }
.travel-theme { font-size: 28rpx; color: var(--color-primary); margin-bottom: 16rpx; font-style: italic; }
.travel-desc { font-size: 26rpx; line-height: 1.8; color: var(--color-text-secondary); }

.travel-days {  }
.day-card { margin: 16rpx 0; padding: 28rpx 32rpx; }
.day-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.day-badge {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: var(--color-primary); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700;
}
.day-city { font-size: 32rpx; font-weight: 600; }
.day-poem-title { font-size: 28rpx; color: var(--color-accent); margin: 8rpx 0 4rpx; }
.day-poem-author { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 12rpx; }
.day-poem-lines { margin: 12rpx 0; }
.day-line { font-size: 28rpx; line-height: 2; color: #4a4a4a; }
.day-note {
  margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx dashed var(--color-border);
  font-size: 24rpx; color: var(--color-text-secondary);
}
