.page-root {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 100%;
}

/* ===== 朝代筛选栏 ===== */
.dynasty-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.dynasty-scroll {
  white-space: nowrap;
  width: 100%;
}

.dynasty-item {
  display: inline-block;
  padding: 8rpx 24rpx;
  margin: 0 6rpx;
  font-size: 26rpx;
  color: #5a5a5a;
  border-radius: 30rpx;
}

.dynasty-item.active {
  background: var(--color-primary);
  color: #fff;
}

/* 朝代展开/收起按钮 */
.toggle-dynasty {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* ===== 定位按钮 ===== */
.locate-btn {
  position: absolute;
  bottom: 180rpx;
  right: 30rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.locate-text {
  font-size: 40rpx;
  color: var(--color-accent);
}

/* ===== 加载提示 ===== */
.loading-mask {
  position: absolute;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}
