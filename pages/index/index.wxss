.page-root { width: 100%; height: 100vh; position: relative; overflow: hidden; }
.map { width: 100%; height: 100%; }

/* ===== #1 朝代筛选：按钮 + chips 下拉 ===== */
.dynasty-trigger {
  position: absolute; top: 32rpx; left: 24rpx;
  display: flex; align-items: center; gap: 4rpx;
  background: rgba(255, 255, 255, 0.95); padding: 12rpx 20rpx;
  border-radius: 40rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  z-index: 10; transition: all 0.2s;
}
.dynasty-trigger:active { transform: scale(0.94); }
.trigger-text { font-size: 26rpx; color: var(--color-text); font-weight: 500; }
.trigger-arrow { font-size: 20rpx; transition: transform 0.2s; color: var(--color-text-secondary); }
.trigger-arrow.open { transform: rotate(180deg); }

/* chips 下拉 */
.dynasty-chips {
  position: absolute; top: 96rpx; left: 24rpx; right: 24rpx;
  background: rgba(255, 255, 255, 0.96); border-radius: 24rpx;
  padding: 16rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  z-index: 10; max-height: 0; overflow: hidden; opacity: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.dynasty-chips.open { max-height: 200rpx; opacity: 1; }
.chips-scroll { white-space: nowrap; width: 100%; }
.chip {
  display: inline-block; padding: 10rpx 24rpx; margin: 0 8rpx;
  font-size: 24rpx; color: #5a5a5a; border-radius: 30rpx;
  background: #f5f3ee; transition: all 0.2s;
}
.chip:active { transform: scale(0.9); }
.chip.active { background: var(--color-primary); color: #fff; }

/* ===== 顶部右侧圆形按钮组 ===== */
.top-right { position: absolute; top: 32rpx; right: 24rpx; display: flex; gap: 16rpx; z-index: 10; }
.circle-btn {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.95); box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; transition: all 0.15s;
}
.circle-btn:active { transform: scale(0.9); }
.circle-btn.active { background: #fff0f0; box-shadow: 0 0 0 3rpx rgba(139,26,26,0.2); }

/* ===== #2 今日推荐弹窗（Google Maps 卡片 + Apple Music 浮窗） ===== */
.featured-card {
  position: absolute; bottom: 160rpx; left: 24rpx; right: 24rpx;
  background: #fff; border-radius: 28rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
  overflow: hidden; z-index: 5;
  animation: cardSlideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
@keyframes cardSlideUp {
  from { transform: translateY(120%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.featured-bar { height: 4rpx; background: linear-gradient(90deg, #8b1a1a, #2d5d7b); }
.featured-body { padding: 32rpx; }
.featured-meta { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.featured-tag {
  min-width: 36rpx; height: 36rpx; background: var(--color-primary); color: #fff;
  border-radius: 8rpx; font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.featured-location { font-size: 24rpx; color: var(--color-text-secondary); }
.featured-title { font-size: 34rpx; font-weight: 700; color: var(--color-text); margin-bottom: 6rpx; }
.featured-author { font-size: 24rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.featured-line { font-size: 28rpx; color: #5a5a5a; line-height: 1.8; letter-spacing: 0.05em; }
.featured-close {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%; background: #f5f3ee;
  display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #888;
}

/* ===== 加载提示 ===== */
.loading-mask {
  position: absolute; bottom: 200rpx; left: 50%; transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6); color: #fff;
  padding: 16rpx 40rpx; border-radius: 30rpx; font-size: 26rpx;
}

/* ===== M6: 冷启动引导 ===== */
.guide-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(248, 246, 240, 0.96); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.guide-card { width: 580rpx; text-align: center; padding: 60rpx 48rpx; }
.guide-logo {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #8b1a1a, #2d5d7b); color: #fff;
  font-size: 56rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; margin: 0 auto 28rpx;
}
.guide-title { font-size: 40rpx; font-weight: 700; margin-bottom: 12rpx; }
.guide-desc { font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 40rpx; }
.guide-steps { text-align: left; margin-bottom: 40rpx; }
.guide-step { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 20rpx; }
.step-num {
  width: 40rpx; height: 40rpx; border-radius: 50%; flex-shrink: 0;
  background: var(--color-primary); color: #fff;
  font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.step-text { font-size: 26rpx; color: #5a5a5a; line-height: 1.6; padding-top: 4rpx; }
.guide-btn {
  background: var(--color-primary); color: #fff;
  border-radius: 40rpx; padding: 20rpx 0; font-size: 28rpx;
}

/* ===== 旅行路线面板 ===== */
.route-panel {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(255, 255, 255, 0.97); border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.1); padding-bottom: env(safe-area-inset-bottom);
  max-height: 50vh; z-index: 20;
}
.panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; font-size: 30rpx; font-weight: 600;
  border-bottom: 1rpx solid var(--color-border);
}
.panel-close { width: 48rpx; height: 48rpx; text-align: center; line-height: 44rpx; font-size: 36rpx; color: #999; }
.route-scroll { max-height: 42vh; padding: 16rpx 24rpx; }
.route-card {
  padding: 24rpx; margin: 12rpx 0; border-radius: 16rpx;
  background: #faf9f5; border-left: 8rpx solid transparent;
  transition: all 0.15s;
}
.route-card:active { transform: scale(0.98); }
.route-card.active { background: #fff; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08); }
.route-name { font-size: 30rpx; font-weight: 600; padding-left: 16rpx; }
.route-meta { font-size: 22rpx; color: var(--color-text-secondary); padding-left: 16rpx; margin-top: 4rpx; }
.route-points { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; padding-left: 16rpx; }
.route-pt { font-size: 22rpx; color: var(--color-accent); }
