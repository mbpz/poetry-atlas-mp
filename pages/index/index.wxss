/* ===== 首页：全屏地图 + 宣纸淡墨浮层 =====
   仍给 cover-view tabBar 留底（tab 高 112rpx + 安全区），避免地图贴边难看 */
.page-root { width: 100%; height: 100vh; position: relative; overflow: hidden; }
.map {
  width: 100%;
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
}

/* ===== #1 朝代筛选：印章触发器 + chips ===== */
.dynasty-trigger {
  position: absolute; top: 32rpx; left: 24rpx;
  display: flex; align-items: center; gap: 6rpx;
  background: rgba(255, 253, 249, 0.92); backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  padding: 12rpx 22rpx; border-radius: 40rpx;
  border: 1rpx solid var(--ink-line);
  box-shadow: 0 2rpx 12rpx rgba(120, 100, 70, 0.1);
  z-index: 10;
}
.trigger-text { font-size: 26rpx; color: var(--cinnabar); font-weight: 600; letter-spacing: 0.08em; }
.trigger-arrow { font-size: 20rpx; transition: transform 0.2s; color: var(--gold); }
.trigger-arrow.open { transform: rotate(180deg); }

.dynasty-chips {
  position: absolute; top: 120rpx; left: 24rpx; right: 24rpx;
  background: rgba(255, 253, 249, 0.95); backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: 24rpx; padding: 16rpx;
  border: 1rpx solid var(--ink-line);
  box-shadow: 0 4rpx 20rpx rgba(120, 100, 70, 0.12);
  z-index: 20;
  animation: chipsIn 0.25s ease;
}
@keyframes chipsIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.chips-scroll { white-space: nowrap; width: 100%; }
.chip {
  display: inline-block; padding: 10rpx 24rpx; margin: 0 8rpx;
  font-size: 24rpx; color: var(--paper-text-2); border-radius: 30rpx;
  background: var(--ink-surface-2); border: 1rpx solid var(--ink-line);
  transition: all 0.2s;
}
.chip.active { background: var(--cinnabar); color: #fff; border-color: var(--cinnabar); }

/* ===== 顶部右侧工具按钮：竖排胶囊（双字标签） ===== */
.top-right {
  position: absolute; top: 24rpx; right: 24rpx;
  display: flex; flex-direction: column; gap: 14rpx; z-index: 10;
}
.circle-btn {
  height: 64rpx; padding: 0 24rpx; border-radius: 32rpx;
  background: rgba(255, 253, 249, 0.9); backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid var(--ink-line);
  box-shadow: 0 2rpx 12rpx rgba(120, 100, 70, 0.1);
  display: flex; align-items: center; justify-content: center;
}
.circle-btn.active { border-color: var(--cinnabar); box-shadow: 0 0 0 2rpx rgba(158,43,35,0.2); }
.btn-txt {
  font-size: 24rpx; color: var(--paper-text);
  transition: color 0.2s; line-height: 1; letter-spacing: 0.08em;
}
.circle-btn.active .btn-txt { color: var(--cinnabar); }
.circle-btn:active .btn-txt { color: var(--cinnabar-soft); }
.circle-btn.disabled { opacity: 0.58; }
.avatar-btn { background: rgba(158, 43, 35, 0.08); border-color: rgba(158,43,35,0.3); }
.avatar-btn .btn-txt { color: var(--cinnabar); }

/* ===== #2 今日推荐卡片 ===== */
.featured-card {
  position: absolute;
  bottom: calc(112rpx + env(safe-area-inset-bottom) + 24rpx);
  left: 24rpx; right: 24rpx;
  background: var(--ink-surface); border-radius: 24rpx;
  border: 1rpx solid var(--ink-line);
  box-shadow: 0 8rpx 32rpx rgba(120, 100, 70, 0.14);
  overflow: hidden; z-index: 5;
  animation: cardSlideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
@keyframes cardSlideUp {
  from { transform: translateY(120%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.featured-bar { height: 3rpx; background: linear-gradient(90deg, var(--cinnabar), var(--gold)); }
.featured-body { padding: 28rpx 32rpx; }
.featured-meta { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.featured-tag {
  min-width: 36rpx; height: 36rpx; background: var(--cinnabar); color: #fff;
  border-radius: 8rpx; font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.featured-location { font-size: 24rpx; color: var(--paper-text-2); }
.featured-title { font-size: 36rpx; font-weight: 700; color: var(--paper-text); margin-bottom: 6rpx; letter-spacing: 0.06em; }
.featured-author { font-size: 24rpx; color: var(--gold); margin-bottom: 16rpx; }
.featured-line { font-size: 28rpx; color: var(--paper-text-2); line-height: 1.8; letter-spacing: 0.08em; }
.featured-close {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%; background: var(--ink-surface-2);
  display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: var(--paper-text-2);
}

/* ===== 下滑关闭指示条 ===== */
.featured-handle { display: flex; justify-content: center; padding: 10rpx 0 4rpx; }
.featured-handle-bar { width: 72rpx; height: 5rpx; border-radius: 3rpx; background: var(--ink-line); }

/* ===== 加载提示 ===== */
.loading-mask {
  position: absolute; bottom: 200rpx; left: 50%; transform: translateX(-50%);
  background: rgba(58, 54, 50, 0.85); color: #fff;
  padding: 16rpx 40rpx; border-radius: 30rpx; font-size: 26rpx; z-index: 30;
}

/* ===== 冷启动引导 ===== */
.guide-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(246, 241, 228, 0.97); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.guide-card { width: 580rpx; text-align: center; padding: 60rpx 48rpx; }
.guide-logo {
  width: 128rpx; height: 128rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--cinnabar), var(--gold)); color: #fff;
  font-size: 60rpx; font-weight: 700; letter-spacing: 0.05em;
  display: flex; align-items: center; justify-content: center; margin: 0 auto 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(158, 43, 35, 0.3);
}
.guide-title { font-size: 44rpx; font-weight: 700; margin-bottom: 12rpx; color: var(--cinnabar); letter-spacing: 0.1em; }
.guide-desc { font-size: 26rpx; color: var(--paper-text-2); margin-bottom: 40rpx; }
.guide-steps { text-align: left; margin-bottom: 40rpx; }
.guide-step { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 20rpx; }
.step-num {
  width: 40rpx; height: 40rpx; border-radius: 50%; flex-shrink: 0;
  background: var(--cinnabar); color: #fff;
  font-size: 22rpx; display: flex; align-items: center; justify-content: center;
}
.step-text { font-size: 26rpx; color: var(--paper-text-2); line-height: 1.6; padding-top: 4rpx; }

/* ===== 旅行路线面板（底部抽屉） ===== */
.route-panel {
  position: absolute;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  left: 0; right: 0;
  background: rgba(255, 253, 249, 0.97); border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(120, 100, 70, 0.12);
  border-top: 1rpx solid var(--ink-line);
  max-height: 55vh; z-index: 20;
}
.panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; font-size: 30rpx; font-weight: 600;
  border-bottom: 1rpx solid var(--ink-line);
}
.panel-close { width: 48rpx; height: 48rpx; text-align: center; line-height: 44rpx; font-size: 36rpx; color: var(--paper-text-2); }
.panel-actions { display: flex; align-items: center; gap: 12rpx; }
.panel-act {
  padding: 10rpx 22rpx; border-radius: 24rpx;
  font-size: 24rpx; letter-spacing: 0.08em;
  background: var(--ink-surface-2); color: var(--paper-text);
  border: 1rpx solid var(--ink-line);
}
.panel-act-primary { background: var(--cinnabar); color: #fff; border-color: var(--cinnabar); }
.route-scroll { max-height: 47vh; padding: 16rpx 24rpx; }
.route-card {
  padding: 24rpx; margin: 12rpx 0; border-radius: 12rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.15s;
}
.route-card.active { background: var(--ink-surface-2); box-shadow: 0 2rpx 12rpx rgba(120,100,70,0.1); }
.route-name { font-size: 30rpx; font-weight: 600; padding-left: 16rpx; color: var(--paper-text); }
.route-meta { font-size: 22rpx; color: var(--paper-text-2); padding-left: 16rpx; margin-top: 4rpx; }
.route-points { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; padding-left: 16rpx; }
.route-pt { font-size: 22rpx; color: var(--teal); }
