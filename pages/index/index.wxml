<!-- 首页：全屏地图 + 沉浸水墨浮层 -->
<view class="page-root">

  <!-- 全屏地图 -->
  <map
    id="poetry-map"
    class="map"
    longitude="{{longitude}}"
    latitude="{{latitude}}"
    scale="{{scale}}"
    min-scale="{{minScale}}"
    max-scale="{{maxScale}}"
    markers="{{markers}}"
    polyline="{{polyline}}"
    bindmarkertap="onMarkerTap"
    bindregionchange="onRegionChange"
    show-location="{{hasLocation}}"
    enable-zoom
    enable-scroll
    enable-rotate="{{false}}"
  ></map>

  <!-- #1 顶部朝代筛选按钮（印章触发器）-->
  <view class="dynasty-trigger spring-btn" bindtap="onToggleDynastyBar">
    <text class="trigger-text">{{selectedDynasty || '朝代'}}</text>
    <view class="trigger-arrow {{showDynastyBar ? 'open' : ''}}">▾</view>
  </view>

  <!-- 朝代 chips 下拉 -->
  <view wx:if="{{showDynastyBar}}" class="dynasty-chips">
    <scroll-view scroll-x class="chips-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="chip spring-btn {{selectedDynasty === '' ? 'active' : ''}}"
        bindtap="onSelectDynasty" data-dynasty=""
      >全部</view>
      <view
        wx:for="{{dynasties}}" wx:key="*this"
        class="chip spring-btn {{selectedDynasty === item ? 'active' : ''}}"
        data-dynasty="{{item}}" bindtap="onSelectDynasty"
      >{{item}}</view>
    </scroll-view>
  </view>

  <!-- 顶部右侧工具按钮（双字标签，功能一目了然）-->
  <view wx:if="{{!showDynastyBar}}" class="top-right">
    <view class="circle-btn spring-btn {{heatMode ? 'active' : ''}}" bindtap="onToggleHeat">
      <text class="btn-txt">热力</text>
    </view>
    <view class="circle-btn spring-btn" bindtap="onToggleRoutePanel">
      <text class="btn-txt">路线</text>
    </view>
    <view class="circle-btn spring-btn {{locating ? 'disabled' : ''}}" bindtap="onLocate">
      <text class="btn-txt">{{locating ? '定位中' : '定位'}}</text>
    </view>
    <view class="circle-btn spring-btn avatar-btn" bindtap="onTapProfile">
      <text class="btn-txt">我的</text>
    </view>
  </view>

  <!-- #2 底部"今日推荐"卡片（下滑关闭 + × 关闭）-->
  <view wx:if="{{!loading && !showGuide && featuredPoem && !featuredHidden}}"
    class="featured-card" bindtap="onFeaturedTap"
    bindtouchstart="onFeaturedTouch" bindtouchmove="onFeaturedMove" bindtouchend="onFeaturedEnd">
    <!-- 下滑指示条 -->
    <view class="featured-handle"><view class="featured-handle-bar"></view></view>
    <view class="featured-body">
      <view class="featured-meta">
        <view class="featured-tag">今</view>
        <text class="featured-location">{{featuredPlace}}</text>
      </view>
      <view class="featured-title">{{featuredPoem.title}}</view>
      <view class="featured-author">{{featuredPoem.dynasty}} · {{featuredPoem.author}}</view>
      <view class="featured-line">{{featuredPoem.firstLine}}</view>
    </view>
    <view class="featured-close spring-btn" catchtap="onFeaturedHide">×</view>
  </view>

  <!-- 旅行路线面板（底部抽屉）-->
  <view wx:if="{{showRoutePanel}}" class="route-panel">
    <view class="panel-header">
      <text class="gold-title">主题旅行路线</text>
      <view class="panel-actions">
        <view class="panel-act spring-btn" bindtap="onOpenMyRoutes">我的</view>
        <view class="panel-act panel-act-primary spring-btn" bindtap="onOpenCreateRoute">+ 新建</view>
        <view class="panel-close spring-btn" bindtap="onToggleRoutePanel">×</view>
      </view>
    </view>
    <scroll-view scroll-y class="route-scroll" enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{routes}}" wx:key="id"
        class="route-card card-accent spring-card {{activeRouteId === item.id ? 'active' : ''}}"
        style="border-left-color:{{item.color}}"
        data-id="{{item.id}}" bindtap="onSelectRoute"
      >
        <view class="route-name">{{item.name}}</view>
        <view class="route-meta">{{item.points.length}} 站 · 推荐</view>
        <view class="route-points">
          <text wx:for="{{item.points}}" wx:for-item="pt" wx:key="name" class="route-pt">{{pt.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 加载态 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>载入诗意…</text>
  </view>

  <view wx:if="{{!loading && markerError}}" class="map-state card">
    <view class="map-state-title">地点暂时没有加载出来</view>
    <view class="map-state-desc">{{markerError}}</view>
    <view class="map-state-actions">
      <view class="map-state-action primary spring-btn" bindtap="onRetryMarkers">重新加载</view>
      <view wx:if="{{selectedDynasty}}" class="map-state-action spring-btn" bindtap="onClearMapFilter">清除筛选</view>
    </view>
  </view>

  <view wx:if="{{!loading && !markerError && markers.length === 0}}" class="map-state card">
    <view class="map-state-title">这片视野还没有诗词地点</view>
    <view class="map-state-desc">可以清除朝代筛选，或缩放、拖动地图继续发现。</view>
    <view class="map-state-actions">
      <view wx:if="{{selectedDynasty}}" class="map-state-action primary spring-btn" bindtap="onClearMapFilter">查看全部朝代</view>
      <view class="map-state-action spring-btn" bindtap="onRetryMarkers">重新加载</view>
    </view>
  </view>

  <!-- 定位失败后的非阻断降级面板 -->
  <view wx:if="{{showLocationFallback}}" class="location-fallback-mask" catchtouchmove="noop">
    <view class="location-fallback card" catchtap="noop">
      <view class="fallback-head">
        <view class="fallback-title">{{showCityPicker ? '选择浏览城市' : locationFailure.title}}</view>
        <view class="fallback-close spring-btn" bindtap="onLocationFallbackClose">×</view>
      </view>

      <block wx:if="{{showCityPicker}}">
        <view class="fallback-desc">选择城市后仍可浏览地点与诗词，不需要定位授权。</view>
        <scroll-view scroll-y class="city-list" enhanced show-scrollbar="{{false}}">
          <view
            wx:for="{{manualCities}}"
            wx:key="id"
            class="city-item spring-btn"
            data-id="{{item.id}}"
            bindtap="onSelectManualCity"
          >
            <text>{{item.name}}</text>
            <text class="city-enter">进入</text>
          </view>
        </scroll-view>
        <view class="fallback-action secondary" bindtap="onCityPickerBack">返回定位选项</view>
      </block>

      <block wx:else>
        <view class="fallback-desc">{{locationFailure.message}}</view>
        <view
          wx:if="{{locationFailure.action === 'open-mini-setting' || locationFailure.action === 'open-app-setting'}}"
          class="fallback-action primary"
          bindtap="onLocationPrimary"
        >{{locationFailure.confirmText}}</view>
        <view class="fallback-action primary" bindtap="onLocationRetry">重试定位</view>
        <view class="fallback-action secondary" bindtap="onOpenCityPicker">手动选择城市</view>
        <view class="fallback-action ghost" bindtap="onBrowseNationwide">浏览全国地图</view>
      </block>
    </view>
  </view>

  <!-- 冷启动引导 -->
  <view wx:if="{{showGuide}}" class="guide-mask">
    <view class="guide-card" catchtap="noop">
      <view class="guide-logo">诗</view>
      <view class="guide-title">诗词地图</view>
      <view class="guide-desc">在地图上发现每首诗词的故乡</view>
      <view class="guide-steps">
        <view class="guide-step"><text class="step-num">1</text><text class="step-text">拖动地图或搜索，寻找诗词地点</text></view>
        <view class="guide-step"><text class="step-num">2</text><text class="step-text">点击诗词，查看注释、译文、赏析</text></view>
        <view class="guide-step"><text class="step-num">3</text><text class="step-text">收藏诗词，规划属于自己的诗意路线</text></view>
      </view>
      <view class="guide-btn btn-gold" bindtap="onGuideClose">开启旅程</view>
    </view>
  </view>

  <!-- 隐私协议弹框（首次启动全屏阻断，必须在引导前决策）-->
  <privacy-dialog id="privacyDialog" bind:agreed="onPrivacyAgreed" />
</view>
