<!-- 地图首页：全屏地图 + 朝代筛选 + 时间轴 + 热力 + 旅行路线 -->
<view class="page-root">
  <map
    id="poetry-map"
    class="map"
    longitude="{{longitude}}"
    latitude="{{latitude}}"
    scale="{{scale}}"
    min-scale="{{minScale}}"
    max-scale="{{maxScale}}"
    markers="{{markers}}"
    polyline="{{polyline}}"
    bindmarkertap="onMarkerTap"
    bindregionchange="onRegionChange"
    show-location="{{hasLocation}}"
    enable-zoom
    enable-scroll
    enable-rotate="{{false}}"
    style="width:100%;height:100%;"
  ></map>

  <!-- 朝代筛选横条 -->
  <view wx:if="{{showDynastyBar}}" class="dynasty-bar">
    <scroll-view scroll-x class="dynasty-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="dynasty-item {{selectedDynasty === '' ? 'active' : ''}}"
        bindtap="onSelectDynasty"
        data-dynasty=""
      >全部</view>
      <view
        wx:for="{{dynasties}}"
        wx:key="*this"
        class="dynasty-item {{selectedDynasty === item ? 'active' : ''}}"
        data-dynasty="{{item}}"
        bindtap="onSelectDynasty"
      >{{item}}</view>
    </scroll-view>
  </view>

  <!-- 顶部功能按钮组 -->
  <view class="top-controls">
    <view class="ctrl-btn" bindtap="onToggleDynastyBar">
      <text>{{showDynastyBar ? '收起' : '朝代'}}</text>
    </view>
    <view class="ctrl-btn {{heatMode ? 'active' : ''}}" bindtap="onToggleHeat">
      <text>热力</text>
    </view>
    <view class="ctrl-btn {{showTimeline ? 'active' : ''}}" bindtap="onToggleTimeline">
      <text>时间轴</text>
    </view>
    <view class="ctrl-btn {{showRoutePanel ? 'active' : ''}}" bindtap="onToggleRoutePanel">
      <text>路线</text>
    </view>
  </view>

  <!-- 定位按钮 -->
  <view class="locate-btn" bindtap="onLocate">
    <text class="locate-text">◎</text>
  </view>

  <!-- M4: 朝代时间轴面板 -->
  <view wx:if="{{showTimeline}}" class="timeline-panel">
    <view class="panel-header">
      <text>朝代时间轴</text>
      <view class="panel-close" bindtap="onToggleTimeline">×</view>
    </view>
    <scroll-view scroll-x class="timeline-scroll" enhanced show-scrollbar="{{false}}">
      <view class="timeline-track">
        <view class="timeline-line"></view>
        <view
          wx:for="{{timelineDynasties}}"
          wx:key="name"
          class="timeline-node {{selectedDynasty === item.name ? 'active' : ''}}"
          data-dynasty="{{item.name}}"
          bindtap="onTimelineSelect"
        >
          <view class="timeline-dot"></view>
          <view class="timeline-name">{{item.name}}</view>
          <view class="timeline-years">{{item.start_year}}~{{item.end_year}}</view>
          <view class="timeline-count">{{item.poem_count}}首</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- M4: 旅行路线面板 -->
  <view wx:if="{{showRoutePanel}}" class="route-panel">
    <view class="panel-header">
      <text>主题旅行路线</text>
      <view class="panel-close" bindtap="onToggleRoutePanel">×</view>
    </view>
    <scroll-view scroll-y class="route-scroll">
      <view
        wx:for="{{routes}}"
        wx:key="id"
        class="route-card {{activeRouteId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onSelectRoute"
      >
        <view class="route-name" style="border-left-color:{{item.color}}">{{item.name}}</view>
        <view class="route-meta">{{item.points.length}} 站 · 点击在地图上查看路线</view>
        <view class="route-points">
          <text wx:for="{{item.points}}" wx:for-item="pt" wx:key="name" class="route-pt">{{pt.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 加载提示 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>载入诗意…</text>
  </view>

  <!-- M6: 冷启动引导 -->
  <view wx:if="{{showGuide}}" class="guide-mask">
    <view class="guide-card" catchtap>
      <view class="guide-logo">诗</view>
      <view class="guide-title">诗词地图</view>
      <view class="guide-desc">在地图上发现每首诗词的故乡</view>
      <view class="guide-steps">
        <view class="guide-step">
          <text class="step-num">1</text>
          <text class="step-text">拖动地图或搜索，寻找诗词地点</text>
        </view>
        <view class="guide-step">
          <text class="step-num">2</text>
          <text class="step-text">点击诗词，查看注释、译文、赏析</text>
        </view>
        <view class="guide-step">
          <text class="step-num">3</text>
          <text class="step-text">AI 深度解读典故、情感与背景</text>
        </view>
      </view>
      <view class="guide-btn" bindtap="onGuideClose">开启旅程</view>
    </view>
  </view>
</view>
