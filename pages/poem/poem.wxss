.page { min-height: 100vh; padding: 24rpx 24rpx 60rpx; }

.poem-hero { padding: 40rpx 36rpx; }
.poem-title-row { display: flex; align-items: flex-start; justify-content: space-between; }
.poem-title {
  font-size: 40rpx; font-weight: 700; color: var(--color-text);
  flex: 1; line-height: 1.4;
}
.fav-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #ccc; background: #f5f5f5; margin-left: 16rpx;
}
.fav-btn.active { color: #e63946; background: #fff0f0; }

.poem-subtitle { display: flex; align-items: center; gap: 16rpx; margin: 16rpx 0 24rpx; }
.poem-author-txt { font-size: 26rpx; color: var(--color-text-secondary); }

.poem-content { margin-top: 16rpx; }
.poem-line {
  font-size: 32rpx; line-height: 2.2; color: #3a3a3a;
  letter-spacing: 0.08em; text-align: center;
}

/* 解读 */
.interpret-card { margin-top: 24rpx; padding: 0; overflow: hidden; }
.tab-bar { display: flex; border-bottom: 1rpx solid var(--color-border); }
.tab-item {
  flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: var(--color-text-secondary);
}
.tab-item.active { color: var(--color-primary); font-weight: 600; border-bottom: 4rpx solid var(--color-primary); }
.tab-body { padding: 32rpx; min-height: 200rpx; }
.interpret-text { font-size: 28rpx; line-height: 1.9; color: #4a4a4a; white-space: pre-wrap; }
.empty.small { font-size: 26rpx; }

.ai-btn {
  margin: 0 32rpx 32rpx; padding: 20rpx; text-align: center;
  background: linear-gradient(135deg, #2d5d7b, #8b1a1a); color: #fff;
  border-radius: 40rpx; font-size: 26rpx;
}

/* 相关地点 */
.place-card { margin-top: 24rpx; padding: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.place-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.place-tag {
  padding: 10rpx 24rpx; background: var(--color-tag-bg); color: var(--color-primary);
  border-radius: 30rpx; font-size: 24rpx;
}

/* AI 解析浮层 */
.ai-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5); z-index: 100;
  display: flex; align-items: flex-end;
}
.ai-panel {
  width: 100%; max-height: 80vh; background: #fff;
  border-radius: 24rpx 24rpx 0 0; display: flex; flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.ai-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; font-size: 30rpx; font-weight: 600;
  border-bottom: 1rpx solid var(--color-border);
}
.ai-panel-close { width: 48rpx; height: 48rpx; text-align: center; line-height: 44rpx; font-size: 36rpx; color: #999; }
.ai-panel-body { flex: 1; padding: 24rpx 32rpx; max-height: 70vh; }
.ai-loading { text-align: center; color: var(--color-text-secondary); padding: 60rpx 0; }

.ai-section { margin-bottom: 32rpx; }
.ai-section-title {
  font-size: 26rpx; font-weight: 600; color: var(--color-primary);
  margin-bottom: 12rpx; padding-left: 16rpx; border-left: 6rpx solid var(--color-primary);
}
.ai-section-text { font-size: 28rpx; line-height: 1.9; color: #4a4a4a; white-space: pre-wrap; }

.ai-allusion { margin-bottom: 20rpx; padding: 16rpx; background: #faf9f5; border-radius: 12rpx; }
.ai-allusion-phrase { font-size: 28rpx; font-weight: 600; color: var(--color-accent); }
.ai-allusion-source { font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.ai-allusion-meaning { font-size: 26rpx; color: #5a5a5a; margin-top: 8rpx; }

.ai-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.ai-tag { padding: 6rpx 20rpx; background: var(--color-tag-bg); color: var(--color-primary); border-radius: 20rpx; font-size: 24rpx; }

.ai-raw { font-size: 28rpx; line-height: 1.9; color: #4a4a4a; white-space: pre-wrap; }
