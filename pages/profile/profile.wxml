<!-- 我的 -->
<view class="page">
  <view class="profile-hero card">
    <view class="profile-avatar">诗</view>
    <view class="profile-name">诗词爱好者</view>
    <view class="profile-sub">OPENID 自动登录 · 无需注册</view>
  </view>

  <view class="card stats-card">
    <view class="stat-item" bindtap="onTapFavorites">
      <view class="stat-num">{{favCount}}</view>
      <view class="stat-label">收藏</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">—</view>
      <view class="stat-label">足迹（开发中）</view>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="onTapFavorites">
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="onTapAbout">
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="profile-footer">v{{version}} · 数据驱动 CloudBase</view>
</view>
