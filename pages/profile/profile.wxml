<!-- 我的 — 微信头像昵称 + 个人数据 Hub -->
<view class="page">
  <view class="profile-hero card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="profile-avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="profile-avatar">{{avatarText}}</view>
    </button>

    <input
      class="profile-name-input"
      type="nickname"
      maxlength="12"
      placeholder="点击填写微信昵称"
      value="{{nickname}}"
      bindblur="onNicknameBlur"
    />

    <view class="profile-sub">
      {{savingAvatar || savingNickname ? '正在保存资料…' : (hasProfile ? '已使用微信资料' : '点击头像与昵称，授权使用微信信息')}}
    </view>
    <view wx:if="{{profileError}}" class="profile-error">
      <text>{{profileError}}</text>
      <text class="profile-error-close" bindtap="onDismissProfileError">知道了</text>
    </view>
  </view>

  <!-- 自建数据统计 -->
  <view class="card stats-card">
    <view class="stat-grid">
      <view class="stat-item" bindtap="onTapFavorites">
        <view class="stat-num">{{favCount}}</view>
        <view class="stat-label">收藏</view>
      </view>
      <view class="stat-item" bindtap="onTapRoute">
        <view class="stat-num">{{stats.routes_count}}</view>
        <view class="stat-label">路线</view>
      </view>
      <view class="stat-item" bindtap="onTapRecitation">
        <view class="stat-num">{{stats.recitation_count}}</view>
        <view class="stat-label">朗诵</view>
      </view>
    </view>
    <view wx:if="{{statsLoading}}" class="stats-status">同步统计中…</view>
    <view wx:if="{{statsError}}" class="stats-error">
      <text>{{statsError}}</text>
      <text class="stats-retry" bindtap="onRetryStats">重试</text>
    </view>
  </view>

  <!-- 入口 Hub -->
  <view class="card hub-card">
    <view class="hub-title">探索更多</view>
    <view class="hub-grid">
      <view class="hub-item" bindtap="onTapRoute" aria-role="button" aria-label="我的路线，仅自己可见">
        <image class="hub-ico" src="/tab-bar-icons/map.svg" mode="aspectFit" />
        <view class="hub-txt">我的路线</view>
        <view class="hub-sub">仅自己可见</view>
      </view>
      <view class="hub-item" bindtap="onTapRecitation" aria-role="button" aria-label="诗词朗诵">
        <image class="hub-ico" src="/tab-bar-icons/audio.svg" mode="aspectFit" />
        <view class="hub-txt">诗词朗诵</view>
      </view>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="onTapFavorites">
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="onTapAbout">
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="profile-footer">v{{version}} · Powered by CloudBase</view>
</view>
