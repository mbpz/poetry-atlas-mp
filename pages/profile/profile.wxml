<!-- 我的（Hub 入口）-->
<view class="page">
  <view class="profile-hero card" bindtap="onEditNickname">
    <view class="profile-avatar">{{avatarText}}</view>
    <view class="profile-name">{{nickname || '点击设置昵称'}}</view>
    <view class="profile-sub">CloudBase 自动身份 · 无需注册</view>
    <view class="profile-wxbtn" catchtap="onUseWxProfile">使用微信昵称</view>
  </view>

  <view class="card openid-card">
    <view class="openid-label">用户标识 (OPENID)</view>
    <view class="openid-row">
      <text class="openid-value">{{openid || '获取中…'}}</text>
      <view class="openid-copy {{openid ? '' : 'disabled'}}" bindtap="onCopyOpenid">
        <text class="openid-copy-txt">复制</text>
      </view>
    </view>
  </view>

  <!-- 自建数据统计 -->
  <view class="card stats-card">
    <view class="stat-grid">
      <view class="stat-item" bindtap="onTapFavorites">
        <view class="stat-num">{{favCount}}</view>
        <view class="stat-label">收藏</view>
      </view>
      <view class="stat-item" bindtap="onTapRoute">
        <view class="stat-num">{{stats.routes_count}}</view>
        <view class="stat-label">路线</view>
      </view>
      <view class="stat-item" bindtap="onTapRecitation">
        <view class="stat-num">{{stats.recitation_count}}</view>
        <view class="stat-label">朗诵</view>
      </view>
    </view>
  </view>

  <!-- 新方向入口 Hub -->
  <view class="card hub-card">
    <view class="hub-title">探索更多</view>
    <view class="hub-grid">
      <view class="hub-item" bindtap="onTapRoute">
        <view class="hub-ico">🗺️</view>
        <view class="hub-txt">我的路线</view>
        <view class="hub-sub">仅自己可见</view>
      </view>
      <view class="hub-item" bindtap="onTapRecitation">
        <view class="hub-ico">🎧</view>
        <view class="hub-txt">诗词朗诵</view>
      </view>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="onTapFavorites">
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="onTapAbout">
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="profile-footer">v{{version}} · Powered by CloudBase</view>
</view>

<!-- 昵称编辑弹窗 -->
<view wx:if="{{showNickModal}}" class="nick-mask" bindtap="onCancelNick">
  <view class="nick-modal" catchtap>
    <view class="nick-title">设置昵称</view>
    <input class="nick-input" placeholder="输入昵称（≤12字）" maxlength="12" value="{{nickname}}" bindinput="onNickInput" focus />
    <view class="nick-btns">
      <view class="nick-btn cancel" bindtap="onCancelNick">取消</view>
      <view class="nick-btn save" bindtap="onSaveNick">保存</view>
    </view>
  </view>
</view>
