/* ===== 我的 — 沉浸水墨 ===== */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom)); }

.profile-hero { text-align: center; padding: 48rpx 32rpx; }
.profile-avatar {
  width: 128rpx; height: 128rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--cinnabar), var(--gold)); color: #fff;
  font-size: 52rpx; font-weight: 700; letter-spacing: 0.05em;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(158, 43, 35, 0.25);
}
.profile-name { font-size: 34rpx; font-weight: 600; margin-bottom: 8rpx; color: var(--paper-text); letter-spacing: 0.08em; }
.profile-sub { font-size: 24rpx; color: var(--paper-text-2); }

.openid-card { margin-top: 16rpx; padding: 24rpx 28rpx; }
.openid-label { font-size: 22rpx; color: var(--paper-text-2); margin-bottom: 8rpx; letter-spacing: 0.05em; }
.openid-row { display: flex; align-items: center; gap: 16rpx; }
.openid-value { flex: 1; font-size: 22rpx; color: var(--paper-text); word-break: break-all; font-family: monospace; }
.openid-copy {
  flex-shrink: 0; padding: 8rpx 20rpx; border-radius: 20rpx;
  background: var(--ink-surface-2); border: 1rpx solid var(--ink-line);
}
.openid-copy:active { transform: scale(0.92); }
.openid-copy-txt { font-size: 22rpx; color: var(--cinnabar); }
.openid-copy.disabled { opacity: 0.4; }

.stats-card { padding: 32rpx; margin-top: 16rpx; transition: background 0.15s; }
.stats-card:active { background: rgba(158, 43, 35, 0.05); }
.stat-item.Center { text-align: center; }
.stat-num { font-size: 52rpx; font-weight: 700; color: var(--cinnabar); }
.stat-label { font-size: 26rpx; color: var(--paper-text-2); margin-top: 8rpx; }

.menu-card { margin-top: 16rpx; padding: 0; overflow: hidden; }
.menu-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx;
}
.menu-item:active { background: rgba(158, 43, 35, 0.05); }
.menu-text { font-size: 28rpx; color: var(--paper-text); }
.menu-arrow { font-size: 36rpx; color: var(--gold); }
.menu-divider { height: 1rpx; background: var(--ink-line); margin: 0 32rpx; }

.profile-footer {
  text-align: center; font-size: 22rpx; color: var(--paper-text-2); margin-top: 48rpx;
}
