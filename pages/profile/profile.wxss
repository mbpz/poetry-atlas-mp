/* ===== 我的 — 沉浸水墨 ===== */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom)); }

.profile-hero {
  text-align: center;
  padding: 48rpx 32rpx 40rpx;
}

/* 重置 button 默认样式，作为头像容器 */
.avatar-btn {
  padding: 0;
  margin: 0 auto 20rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: transparent;
  display: block;
  overflow: hidden;
  line-height: 1;
}
.avatar-btn::after { border: none; }
.avatar-btn:active { opacity: 0.88; }

.profile-avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: block;
  background: var(--ink-surface-2);
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--cinnabar), var(--gold));
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 0.05em;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(158, 43, 35, 0.25);
}

.profile-name-input {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--paper-text);
  letter-spacing: 0.08em;
  margin-bottom: 8rpx;
  padding: 8rpx 16rpx;
  background: transparent;
  border: none;
  height: 64rpx;
  line-height: 64rpx;
}

.profile-sub {
  font-size: 24rpx;
  color: var(--paper-text-2);
}
.profile-error, .stats-error {
  margin-top: 18rpx; padding: 14rpx 18rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: space-between; gap: 16rpx;
  background: rgba(158,43,35,0.06); color: var(--cinnabar); font-size: 22rpx;
}
.profile-error-close, .stats-retry { flex-shrink: 0; text-decoration: underline; }

.stats-card { padding: 32rpx; margin-top: 16rpx; }
.stat-grid { display: flex; flex-direction: row; }
.stat-item { flex: 1; text-align: center; padding: 8rpx 0; }
.stat-item:active { background: rgba(158, 43, 35, 0.04); border-radius: 8rpx; }
.stat-num { font-size: 40rpx; font-weight: 700; color: var(--cinnabar); }
.stat-label { font-size: 22rpx; color: var(--paper-text-2); margin-top: 4rpx; letter-spacing: 0.08em; }
.stats-status { margin-top: 18rpx; text-align: center; color: var(--paper-text-2); font-size: 22rpx; }

.hub-card { margin-top: 16rpx; padding: 28rpx 24rpx; }
.hub-title { font-size: 26rpx; color: var(--paper-text-2); margin-bottom: 20rpx; letter-spacing: 0.08em; }
.hub-grid { display: flex; flex-direction: row; gap: 12rpx; }
.hub-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
}
.hub-item:active { transform: scale(0.95); background: rgba(158, 43, 35, 0.06); }
.hub-ico { width: 48rpx; height: 48rpx; opacity: 0.72; }
.hub-txt { font-size: 22rpx; color: var(--paper-text); letter-spacing: 0.05em; }
.hub-sub { font-size: 20rpx; color: var(--paper-text-2); }

.menu-card { margin-top: 16rpx; padding: 0; overflow: hidden; }
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}
.menu-item:active { background: rgba(158, 43, 35, 0.05); }
.menu-text { font-size: 28rpx; color: var(--paper-text); }
.menu-arrow { font-size: 36rpx; color: var(--gold); }
.menu-divider { height: 1rpx; background: var(--ink-line); margin: 0 32rpx; }

.profile-footer {
  text-align: center;
  font-size: 22rpx;
  color: var(--paper-text-2);
  margin-top: 48rpx;
}
