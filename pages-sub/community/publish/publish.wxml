<!-- 发布动态 -->
<view class="page">
  <!-- 发布隐私提示（必须勾选才能发布）-->
  <view class="card privacy-notice">
    <view class="privacy-notice-text">提示：发布的内容对所有用户可见，请勿包含个人隐私信息。</view>
    <view class="privacy-notice-check">
      <checkbox-group bindchange="onTogglePrivacy">
        <checkbox value="agree" checked="{{privacyAgreed}}" />
      </checkbox-group>
      <text class="privacy-notice-label">我已阅读并同意</text>
    </view>
  </view>

  <!-- 文字输入 -->
  <view class="card write-card">
    <textarea class="write-input"
      placeholder="分享你对诗词的感悟…（最多 {{MAX_CONTENT}} 字）"
      placeholder-class="write-placeholder"
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="{{MAX_CONTENT}}"
      auto-height
      show-confirm-bar="{{false}}"
      cursor-spacing="20"
    />
    <view class="write-counter {{count >= MAX_CONTENT ? 'counter-warn' : ''}}">{{count}}/{{MAX_CONTENT}}</view>
  </view>

  <!-- 图片网格（本地预览 + 删除）-->
  <view class="card img-card">
    <view class="img-grid">
      <view
        wx:for="{{images}}"
        wx:key="*this"
        class="img-cell"
        data-index="{{index}}"
        bindtap="onPreviewImage"
      >
        <image src="{{item}}" class="img-thumb" mode="aspectFill" />
        <view class="img-remove" catchtap="onRemoveImage" data-index="{{index}}">×</view>
      </view>
      <view wx:if="{{images.length < MAX_IMAGES}}" class="img-cell img-add" bindtap="onChooseImages">
        <view class="img-add-ico">+</view>
        <view class="img-add-txt">添加图片</view>
      </view>
    </view>
  </view>

  <!-- 引用一首诗（可选）-->
  <view class="card link-card" wx:if="{{!poemId && !poemTitle}}">
    <view class="link-pick-btn" bindtap="onPickPoem">
      <text class="link-tag-ico">📜</text>
      <text class="link-pick-txt">引用一首诗</text>
      <text class="link-pick-arrow">›</text>
    </view>
  </view>

  <!-- 已关联（从诗词/作者页引用入口自动带入 / 从搜索页选择）-->
  <view class="card link-card" wx:if="{{poemId || poemTitle || authorName}}">
    <view class="link-title">关联</view>
    <view wx:if="{{poemTitle || poemId}}" class="link-tag">
      <text class="link-tag-ico">📜</text>
      <text class="link-tag-txt">{{poemTitle || '诗词'}}</text>
      <text class="link-tag-clear" catchtap="onClearPoem">×</text>
    </view>
    <view wx:if="{{authorName}}" class="link-tag">
      <text class="link-tag-ico">🖌️</text>
      <text class="link-tag-txt">{{authorName}}</text>
      <text class="link-tag-clear" catchtap="onClearAuthor">×</text>
    </view>
    <view class="link-note">在诗词/作者页点「写一首」可自动关联</view>
  </view>

  <!-- 发布按钮 -->
  <view class="submit-bar">
    <view
      class="btn-primary submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
    >{{submitting ? '发布中…' : '发布动态'}}</view>
  </view>
</view>
