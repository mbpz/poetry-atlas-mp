/* 发布动态 — 宣纸淡墨 */
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
}

/* 发布隐私提示 */
.privacy-notice { padding: 24rpx 28rpx; }
.privacy-notice-text {
  font-size: 24rpx; color: var(--paper-text-2); line-height: 1.7;
  margin-bottom: 16rpx;
}
.privacy-notice-check {
  display: flex; align-items: center; gap: 12rpx;
}
.privacy-notice-label { font-size: 26rpx; color: var(--paper-text); }

/* 文字输入 */
.write-card { padding: 28rpx 28rpx 16rpx; position: relative; }
.write-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--paper-text);
}
.write-placeholder { color: var(--paper-text-2); font-size: 28rpx; }
.write-counter {
  text-align: right;
  font-size: 22rpx;
  color: var(--paper-text-2);
  margin-top: 8rpx;
  letter-spacing: 0.05em;
}
.write-counter.counter-warn { color: var(--cinnabar); }

/* 图片网格 */
.img-card { margin-top: 24rpx; padding: 20rpx; }
.img-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-cell {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1 / 1;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: var(--ink-surface-2);
}
.img-thumb { width: 100%; height: 100%; display: block; }
.img-remove {
  position: absolute;
  top: 6rpx; right: 6rpx;
  width: 36rpx; height: 36rpx;
  border-radius: 50%;
  background: rgba(58, 54, 50, 0.6);
  color: #fff;
  font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.img-add {
  border: 2rpx dashed var(--ink-line);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8rpx;
}
.img-add-ico { font-size: 56rpx; color: var(--paper-text-2); line-height: 1; }
.img-add-txt { font-size: 22rpx; color: var(--paper-text-2); }

/* 关联卡 */
.link-card { margin-top: 24rpx; padding: 24rpx 28rpx; }
.link-title { font-size: 26rpx; color: var(--paper-text-2); margin-bottom: 16rpx; letter-spacing: 0.08em; }
.link-tag {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 10rpx 20rpx;
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
  border-radius: 30rpx;
  margin: 0 12rpx 12rpx 0;
}
.link-tag-ico { font-size: 24rpx; }
.link-tag-txt { font-size: 26rpx; color: var(--paper-text); }
.link-tag-clear {
  font-size: 26rpx; color: var(--paper-text-2);
  margin-left: 6rpx; padding: 0 6rpx;
}
.link-note { font-size: 22rpx; color: var(--paper-text-2); margin-top: 8rpx; }

/* 发布按钮 */
.submit-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 48rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--ink-bg);
  border-top: 1rpx solid var(--ink-line);
  z-index: 50;
}
.submit-btn { width: 100%; text-align: center; }
.submit-btn.disabled { opacity: 0.5; }
