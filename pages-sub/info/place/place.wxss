/* ===== 地点详情 — 沉浸水墨 ===== */
.page { min-height: 100vh; padding-bottom: calc(140rpx + env(safe-area-inset-bottom)); }
.page-state-wrap { display: flex; align-items: center; justify-content: center; padding: 48rpx 24rpx; box-sizing: border-box; }
.page-state { width: 100%; padding: 44rpx 36rpx; text-align: center; }
.page-state-title { font-size: 34rpx; font-weight: 700; color: var(--paper-text); }
.page-state-desc { margin-top: 16rpx; font-size: 25rpx; line-height: 1.7; color: var(--paper-text-2); }
.page-state-action {
  min-height: 76rpx; margin-top: 28rpx; border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; background: var(--cinnabar); font-size: 27rpx;
}
.place-map { width: 100%; border-radius: 0; }

.place-info { margin: 24rpx; padding: 32rpx 36rpx; }
.place-name {
  font-size: 46rpx;
  font-weight: 700;
  color: var(--paper-text);
  margin-bottom: 16rpx;
  letter-spacing: 0.08em;
}
.place-meta { display: flex; align-items: center; gap: 20rpx; }
.meta-text { font-size: 26rpx; color: var(--gold); }
.place-desc {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--paper-text-2);
  line-height: 1.7;
}

.dynasty-bar {
  margin: 0 24rpx 16rpx;
  background: var(--ink-surface);
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--ink-line);
}
.dynasty-scroll { white-space: nowrap; width: 100%; }
.dynasty-item {
  display: inline-block;
  padding: 8rpx 24rpx;
  margin: 0 6rpx;
  font-size: 26rpx;
  color: var(--paper-text-2);
  border-radius: 30rpx;
  border: 1rpx solid transparent;
}
.dynasty-item.active { background: var(--cinnabar); color: #fff; }

.poem-section { padding: 0 24rpx; }
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 24rpx 0 16rpx;
  color: var(--gold);
}

.poem-card { margin: 16rpx 0; padding: 28rpx 32rpx; opacity: 0; transform: translateY(20rpx); animation: cardEnter 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
@keyframes cardEnter { to { opacity: 1; transform: translateY(0); } }

.poem-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--paper-text);
}
.poem-author {
  display: flex; align-items: center; gap: 12rpx;
  font-size: 24rpx; color: var(--gold);
  margin-bottom: 16rpx;
}
.poem-lines { margin-top: 8rpx; }
.poem-line { font-size: 28rpx; line-height: 2; color: var(--paper-text-2); letter-spacing: 0.06em; }
.preview-note { margin-top: 12rpx; font-size: 22rpx; color: var(--gold); }
.list-state { padding: 28rpx; text-align: center; font-size: 25rpx; color: var(--paper-text-2); }
.error-state, .empty-state { margin: 16rpx 0; }
.inline-action {
  display: inline-flex; align-items: center; justify-content: center;
  min-height: 64rpx; margin-top: 18rpx; padding: 0 32rpx; border-radius: 32rpx;
  color: var(--cinnabar); background: var(--ink-surface-2); border: 1rpx solid var(--ink-line);
}

.spring-card { transition: transform 0.12s ease, box-shadow 0.12s; box-shadow: 0 2rpx 12rpx rgba(120, 100, 70, 0.1); }
.spring-card:active { transform: scale(0.98); }
.card-pressed { transform: scale(0.97); }
