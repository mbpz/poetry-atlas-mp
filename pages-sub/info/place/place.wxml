<!-- 地点详情页 -->
<view wx:if="{{loading}}" class="page">
  <skeleton rows="2" avatar />
  <skeleton rows="3" />
  <skeleton rows="2" />
</view>
<view wx:elif="{{placeError}}" class="page page-state-wrap">
  <view class="card page-state">
    <view class="page-state-title">地点暂时无法打开</view>
    <view class="page-state-desc">{{placeError}}</view>
    <view class="page-state-action spring-btn" bindtap="onRetryPlace">重新加载</view>
  </view>
</view>
<view class="page" wx:elif="{{place}}">

  <!-- 顶部小地图 -->
  <map id="place-map" class="place-map" longitude="{{mapLongitude}}" latitude="{{mapLatitude}}"
    scale="8" markers="{{markers}}" enable-zoom="{{false}}" enable-scroll="{{false}}"
    style="width:100%;height:240rpx;"></map>

  <!-- 地点信息卡 -->
  <view class="card place-info spring-card" bindtouchstart="onCardTouch" bindtouchend="onCardTouchEnd">
    <view class="place-name">{{place.name}}</view>
    <view class="place-meta">
      <text class="dynasty-tag">{{place.type}}</text>
      <text class="meta-text">诗词 {{place.poem_count}} 首</text>
    </view>
    <view wx:if="{{place.description}}" class="place-desc">{{place.description}}</view>
  </view>

  <!-- 朝代筛选 -->
  <view wx:if="{{dynasties.length}}" class="dynasty-bar">
    <scroll-view scroll-x class="dynasty-scroll" enhanced show-scrollbar="{{false}}">
      <view class="dynasty-item {{selectedDynasty === '' ? 'active' : ''}}"
        bindtap="onSelectDynasty" data-dynasty="">全部</view>
      <view wx:for="{{dynasties}}" wx:key="*this"
        class="dynasty-item {{selectedDynasty === item ? 'active' : ''}} spring-btn"
        data-dynasty="{{item}}" bindtap="onSelectDynasty">{{item}} ({{place.dynasty_stats[item]}})</view>
    </scroll-view>
  </view>

  <!-- 诗词列表 -->
  <view class="poem-section">
    <view class="section-title">相关诗词</view>
    <view
      wx:for="{{poems}}"
      wx:key="_id"
      class="card poem-card spring-card {{touchedIndex === index ? 'card-pressed' : 'card-enter'}}"
      data-poem="{{item}}"
      data-index="{{index}}"
      bindtouchstart="onPoemCardTouch"
      bindtouchend="onPoemCardEnd"
      bindtap="onTapPoem"
    >
      <view class="poem-title">{{item.title}}</view>
      <view class="poem-author">
        <text class="dynasty-tag">{{item.dynasty}}</text>
        <text>{{item.author}}</text>
      </view>
      <view class="poem-lines">
        <view wx:for="{{item.lines}}" wx:for-item="line" wx:key="*this" class="poem-line">{{line}}</view>
      </view>
      <view wx:if="{{item.isPreview}}" class="preview-note">正在载入完整诗文…</view>
    </view>
    <view wx:if="{{loadingPoems}}" class="list-state">正在加载相关诗词…</view>
    <view wx:if="{{!loadingPoems && poemsError}}" class="card list-state error-state">
      <view>{{poemsError}}</view>
      <view class="inline-action spring-btn" bindtap="onRetryPoems">重试</view>
    </view>
    <view wx:if="{{!loadingPoems && !poemsError && !poems.length}}" class="card list-state empty-state">
      <view>暂未收录相关诗词</view>
      <view wx:if="{{selectedDynasty}}" class="inline-action spring-btn" bindtap="onSelectDynasty" data-dynasty="">查看全部朝代</view>
    </view>
    <view wx:if="{{!hasMore && poems.length}}" class="empty">— 到底了 —</view>
  </view>
</view>
