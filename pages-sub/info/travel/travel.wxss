/* ===== 旅行路线详情 — 沉浸水墨 ===== */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom)); }

.travel-hero { padding: 40rpx 36rpx; margin-bottom: 24rpx; }
.travel-name-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.travel-name { font-size: 42rpx; font-weight: 700; color: var(--paper-text); letter-spacing: 0.08em; }
.travel-badge {
  display: inline-block; padding: 2rpx 12rpx; border-radius: 20rpx;
  font-size: 20rpx; color: var(--gold); border: 1rpx solid var(--gold); letter-spacing: 0.1em;
}
.travel-theme { font-size: 28rpx; color: var(--gold); margin-bottom: 16rpx; font-style: italic; }
.travel-desc { font-size: 26rpx; line-height: 1.8; color: var(--paper-text-2); }

.day-card { margin: 16rpx 0; padding: 28rpx 32rpx; }
.day-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.day-badge {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: var(--cinnabar); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700;
}
.day-city { font-size: 32rpx; font-weight: 600; color: var(--paper-text); }
.day-poem-title { font-size: 28rpx; color: var(--teal); margin: 8rpx 0 4rpx; }
.day-poem-author { font-size: 24rpx; color: var(--gold); margin-bottom: 12rpx; }
.day-poem-lines { margin: 12rpx 0; }
.day-line { font-size: 28rpx; line-height: 2; color: var(--paper-text-2); letter-spacing: 0.05em; }
.day-note {
  margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx dashed var(--ink-line);
  font-size: 24rpx; color: var(--paper-text-2);
}
