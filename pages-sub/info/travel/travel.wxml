<!-- 旅行路线详情页 -->
<view class="page" wx:if="{{!loading && route}}">
  <view class="travel-hero card">
    <view class="travel-name-row">
      <view class="travel-name">{{route.name}}</view>
      <view class="travel-badge">{{isDynamic ? '自建·私有' : '示例'}}</view>
    </view>
    <view class="travel-theme">「{{route.theme}}」</view>
    <view class="travel-desc">{{route.description}}</view>
  </view>

  <view class="travel-days">
    <view
      wx:for="{{route.days}}"
      wx:key="day"
      class="day-card card"
      data-day="{{item}}"
      bindtap="onTapPoem"
    >
      <view class="day-header">
        <view class="day-badge">D{{item.day}}</view>
        <view class="day-city">{{item.city}}</view>
      </view>
      <view wx:if="{{item.poemTitle}}" class="day-poem-title">{{item.poemTitle}}</view>
      <view wx:if="{{item.poemAuthor}}" class="day-poem-author">{{item.poemAuthor}}</view>
      <view wx:if="{{item.lines.length}}" class="day-poem-lines">
        <view wx:for="{{item.lines}}" wx:for-item="line" wx:key="*this" class="day-line">{{line}}</view>
      </view>
      <view wx:if="{{item.note}}" class="day-note">{{item.note}}</view>
    </view>
  </view>
</view>

<view wx:if="{{!loading && loadError}}" class="page route-state-wrap">
  <view class="card route-state">
    <view class="route-state-title">路线暂时无法打开</view>
    <view class="route-state-desc">{{loadError}}</view>
    <view class="route-state-action spring-btn" bindtap="onRetryRoute">重新加载</view>
  </view>
</view>

<view wx:if="{{loading}}" class="page">
  <skeleton rows="2" />
  <skeleton rows="4" />
  <skeleton rows="2" />
</view>
