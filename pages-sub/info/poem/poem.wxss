/* ===== 诗词详情 — 沉浸水墨 + 竖排卷轴 ===== */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom)); }

/* 卷轴英雄卡 */
.poem-hero { padding: 0 0 36rpx; position: relative; overflow: hidden; }
.scroll-rod {
  height: 8rpx;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin-bottom: 36rpx;
  opacity: 0.7;
}

.poem-title-row { display: flex; align-items: flex-start; justify-content: space-between; padding: 0 40rpx; }
.poem-title { font-size: 42rpx; font-weight: 700; flex: 1; line-height: 1.4; letter-spacing: 0.1em; }

/* 收藏按钮 */
.fav-btn {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; background: var(--ink-surface-2); margin-left: 16rpx;
  border: 1rpx solid var(--ink-line);
  transition: transform 0.15s, color 0.2s, border-color 0.2s;
}
.fav-btn.off { color: var(--paper-text-2); }
.fav-btn.on { color: var(--cinnabar); border-color: rgba(158,43,35,0.5); box-shadow: 0 0 16rpx rgba(158,43,35,0.2); }
.fav-btn:active { transform: scale(0.8); }

.poem-subtitle { display: flex; align-items: center; gap: 16rpx; margin: 16rpx 40rpx 24rpx; }
.poem-author-txt { font-size: 26rpx; color: var(--gold); }

/* 横/竖排切换 */
.poem-mode-toggle {
  display: flex; justify-content: center; gap: 0; margin: 16rpx 40rpx 28rpx;
}
.mode-btn {
  padding: 8rpx 28rpx; font-size: 24rpx; color: var(--paper-text-2);
  border: 1rpx solid var(--ink-line); letter-spacing: 0.1em;
}
.mode-btn:first-child { border-radius: 30rpx 0 0 30rpx; }
.mode-btn:last-child { border-radius: 0 30rpx 30rpx 0; border-left: none; }
.mode-btn.on { background: var(--cinnabar); color: #fff; border-color: var(--cinnabar); }

/* 横排正文 */
.poem-content { margin-top: 16rpx; padding: 0 40rpx; }
.poem-line { font-size: 32rpx; line-height: 2.2; letter-spacing: 0.1em; text-align: center; }

/* 竖排卷轴（右→左）*/
.poem-scroll-wrap { position: relative; margin: 0 24rpx; }
.poem-scroll-h { white-space: nowrap; padding: 24rpx 0; }
.poem-vertical {
  display: flex; flex-direction: row-reverse; justify-content: center; gap: 0;
}
.poem-v-col {
  display: flex; flex-direction: column; align-items: center;
  margin: 0 8rpx;
}
.poem-v-ch {
  font-size: 36rpx; line-height: 2; letter-spacing: 0.05em;
}

/* 左右淡出 — 暗示可横滑 */
.poem-fade-left, .poem-fade-right {
  position: absolute; top: 0; bottom: 0; width: 40rpx; pointer-events: none; z-index: 2;
}
.poem-fade-left {
  left: 0;
  background: linear-gradient(90deg, var(--ink-bg), transparent);
}
.poem-fade-right {
  right: 0;
  background: linear-gradient(270deg, var(--ink-bg), transparent);
}

/* 印章落款 */
.poem-seal {
  display: inline-block; margin: 28rpx 40rpx 0; padding: 6rpx 18rpx;
  font-size: 22rpx; color: var(--cinnabar);
  border: 2rpx solid var(--cinnabar); border-radius: 6rpx;
  letter-spacing: 0.15em; opacity: 0.85;
}

/* 解读 */
.interpret-card { margin-top: 24rpx; padding: 0; overflow: hidden; }
.tab-bar { display: flex; border-bottom: 1rpx solid var(--ink-line); }
.tab-item {
  flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: var(--paper-text-2);
  position: relative;
}
.tab-item.active { color: var(--gold); font-weight: 600; }
/* 选中态用伪元素下划线，便于做动画 */
.tab-item.active::after {
  content: ''; position: absolute; left: 25%; right: 25%; bottom: 0; height: 4rpx;
  background: var(--gold); border-radius: 2rpx;
}
.tab-body { padding: 32rpx 36rpx; min-height: 200rpx; }
.interpret-text { font-size: 28rpx; line-height: 2; color: var(--paper-text-2); white-space: pre-wrap; }
.empty.small { font-size: 26rpx; }

/* ===== 朗诵入口 ===== */
.recitation-card { margin-top: 24rpx; padding: 24rpx 28rpx; }
.recitation-card.empty { padding: 32rpx 28rpx; }
.recitation-empty-text {
  text-align: center;
  font-size: 26rpx;
  color: var(--paper-text-2);
  letter-spacing: 0.08em;
}
.recitation-list { display: flex; flex-direction: column; gap: 8rpx; margin-top: 8rpx; }
.recitation-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
  transition: transform 0.12s;
}
.recitation-play {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: var(--cinnabar);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.recitation-meta { flex: 1; min-width: 0; }
.recitation-voice { font-size: 26rpx; color: var(--paper-text); font-weight: 600; letter-spacing: 0.06em; }
.recitation-dur { font-size: 22rpx; color: var(--paper-text-2); margin-top: 2rpx; }

.interpret-empty { color: var(--paper-text-2); }

.place-card { margin-top: 24rpx; padding: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.place-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.place-tag {
  padding: 10rpx 24rpx; background: var(--ink-surface-2); color: var(--gold);
  border-radius: 30rpx; font-size: 24rpx; border: 1rpx solid var(--ink-line);
}

.spring-card { transition: transform 0.12s ease; }
.spring-card:active { transform: scale(0.985); }
.spring-btn { transition: transform 0.12s, opacity 0.12s; }
