/* ===== 诗词详情 — 横排沉浸阅读 ===== */
.page { min-height: 100vh; padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom)); }
.page-state-wrap { display: flex; align-items: center; justify-content: center; box-sizing: border-box; }
.page-state { width: 100%; padding: 44rpx 36rpx; text-align: center; }
.page-state-title { font-size: 34rpx; font-weight: 700; color: var(--paper-text); }
.page-state-desc { margin-top: 16rpx; font-size: 25rpx; line-height: 1.7; color: var(--paper-text-2); }
.page-state-action {
  min-height: 76rpx; margin-top: 28rpx; border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; background: var(--cinnabar); font-size: 27rpx;
}

.poem-hero { padding: 0 0 40rpx; position: relative; overflow: hidden; }
.scroll-rod {
  height: 8rpx;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin-bottom: 40rpx;
  opacity: 0.7;
}

.poem-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 0 40rpx;
}
.poem-title {
  font-size: 44rpx;
  font-weight: 700;
  flex: 1;
  line-height: 1.45;
  letter-spacing: 0.12em;
}

.fav-btn {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; background: var(--ink-surface-2); margin-left: 16rpx;
  border: 1rpx solid var(--ink-line);
  transition: transform 0.15s, color 0.2s, border-color 0.2s;
}
.fav-btn.off { color: var(--paper-text-2); }
.fav-btn.on { color: var(--cinnabar); border-color: rgba(158,43,35,0.5); box-shadow: 0 0 16rpx rgba(158,43,35,0.2); }
.fav-btn:active { transform: scale(0.8); }
.fav-btn.busy { opacity: 0.55; }

.poem-subtitle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 20rpx 40rpx 36rpx;
}
.poem-author-txt { font-size: 28rpx; color: var(--gold); letter-spacing: 0.08em; }
.favorite-error {
  margin: -12rpx 40rpx 24rpx; padding: 16rpx 20rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: space-between; gap: 16rpx;
  color: var(--cinnabar); background: rgba(158,43,35,0.06); font-size: 23rpx;
}
.favorite-retry { flex-shrink: 0; text-decoration: underline; }

/* 横排正文：居中、加大字号与行距 */
.poem-content {
  padding: 8rpx 48rpx 12rpx;
}
.poem-line {
  font-size: 36rpx;
  line-height: 2.35;
  letter-spacing: 0.16em;
  text-align: center;
  color: var(--paper-text);
}

.poem-seal {
  display: block;
  width: fit-content;
  margin: 36rpx auto 0;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  color: var(--cinnabar);
  border: 2rpx solid var(--cinnabar);
  border-radius: 6rpx;
  letter-spacing: 0.15em;
  opacity: 0.85;
}

.recitation-card { margin-top: 24rpx; padding: 24rpx 28rpx; }
.source-card { margin-top: 24rpx; padding: 28rpx 32rpx; }
.source-row { display: flex; align-items: flex-start; gap: 24rpx; padding: 12rpx 0; }
.source-label { width: 120rpx; flex-shrink: 0; font-size: 24rpx; color: var(--paper-text-2); }
.source-value { flex: 1; font-size: 24rpx; line-height: 1.6; color: var(--paper-text); }
.status-value { color: var(--cinnabar); font-weight: 600; }
.source-action {
  width: fit-content; min-height: 62rpx; margin-top: 14rpx; padding: 0 26rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--gold); background: var(--ink-surface-2); border: 1rpx solid var(--ink-line);
  border-radius: 32rpx; font-size: 23rpx;
}
.tts-row {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
}
.tts-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 16rpx;
  font-size: 28rpx;
  letter-spacing: 0.08em;
  color: var(--paper-text);
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
  border-radius: 12rpx;
}
.tts-btn.loading {
  opacity: 0.65;
  color: var(--gold);
}
.section-sub {
  margin-top: 28rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: var(--paper-text-2);
  letter-spacing: 0.06em;
}
.recitation-list { display: flex; flex-direction: column; gap: 8rpx; margin-top: 8rpx; }
.recitation-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
  transition: transform 0.12s;
}
.recitation-play {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: var(--cinnabar);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.recitation-meta { flex: 1; min-width: 0; }
.recitation-voice { font-size: 26rpx; color: var(--paper-text); font-weight: 600; letter-spacing: 0.06em; }
.recitation-dur { font-size: 22rpx; color: var(--paper-text-2); margin-top: 2rpx; }

.place-card { margin-top: 24rpx; padding: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.place-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.place-tag {
  padding: 10rpx 24rpx; background: var(--ink-surface-2); color: var(--gold);
  border-radius: 30rpx; font-size: 24rpx; border: 1rpx solid var(--ink-line);
}
.place-error {
  margin-top: 18rpx; padding: 16rpx 20rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: space-between; gap: 16rpx;
  color: var(--cinnabar); background: rgba(158,43,35,0.06); font-size: 23rpx;
}
.place-retry { flex-shrink: 0; text-decoration: underline; }

.spring-card { transition: transform 0.12s ease; }
.spring-card:active { transform: scale(0.985); }
.spring-btn { transition: transform 0.12s, opacity 0.12s; }
