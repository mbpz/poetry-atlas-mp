<!-- 诗词详情页 -->
<view wx:if="{{loading}}" class="page">
  <skeleton rows="2" />
  <skeleton rows="4" />
  <skeleton rows="2" />
</view>
<view class="page" wx:elif="{{poem}}">
  <view class="poem-hero card">
    <view class="poem-title-row">
      <text class="poem-title">{{poem.title}}</text>
      <view class="fav-btn {{isFavorited ? 'active' : ''}}" bindtap="onToggleFavorite">♥</view>
    </view>
    <view class="poem-subtitle">
      <text class="dynasty-tag">{{poem.dynasty}}</text>
      <text class="poem-author-txt">{{poem.author}}</text>
    </view>
    <view class="poem-content">
      <view wx:for="{{poem.lines}}" wx:key="*this" class="poem-line">{{line}}</view>
    </view>
  </view>

  <!-- 解读 Tab -->
  <view class="card interpret-card">
    <view class="tab-bar">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-item {{activeTab === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onSelectTab"
      >{{item.label}}</view>
    </view>
    <view class="tab-body">
      <text wx:if="{{activeTab === 'annotation' && poem.annotation}}" class="interpret-text">{{poem.annotation}}</text>
      <text wx:if="{{activeTab === 'annotation' && !poem.annotation}}" class="empty small">暂无注释</text>

      <text wx:if="{{activeTab === 'translation' && poem.translation}}" class="interpret-text">{{poem.translation}}</text>
      <text wx:if="{{activeTab === 'translation' && !poem.translation}}" class="empty small">暂无译文</text>

      <text wx:if="{{activeTab === 'appreciation' && poem.appreciation}}" class="interpret-text">{{poem.appreciation}}</text>
      <text wx:if="{{activeTab === 'appreciation' && !poem.appreciation}}" class="empty small">暂无赏析</text>
    </view>
    <view class="ai-btn" bindtap="onAskAI">AI 深度解读</view>
  </view>

  <!-- 相关地点 -->
  <view wx:if="{{places.length}}" class="card place-card">
    <view class="section-title">相关地点</view>
    <view class="place-tags">
      <view
        wx:for="{{places}}"
        wx:key="name"
        class="place-tag"
        data-place="{{item}}"
        bindtap="onTapPlace"
      >{{item.name}}</view>
    </view>
  </view>
</view>

<!-- AI 解析浮层 -->
<view wx:if="{{AI.show}}" class="ai-mask" bindtap="onHideAI">
  <view class="ai-panel" catchtap>
    <view class="ai-panel-header">
      <text>AI 深度解读</text>
      <view class="ai-panel-close" bindtap="onHideAI">×</view>
    </view>
    <scroll-view scroll-y class="ai-panel-body" enhanced show-scrollbar="{{false}}">
      <view wx:if="{{AI.loading}}" class="ai-loading">解读中…</view>
      <block wx:elif="{{AI.structured}}">
        <view class="ai-section">
          <view class="ai-section-title">白话译文</view>
          <view class="ai-section-text">{{AI.structured.translation}}</view>
        </view>
        <view class="ai-section" wx:if="{{AI.structured.allusions && AI.structured.allusions.length}}">
          <view class="ai-section-title">典故</view>
          <view wx:for="{{AI.structured.allusions}}" wx:key="phrase" class="ai-allusion">
            <view class="ai-allusion-phrase">{{item.phrase}}</view>
            <view class="ai-allusion-source">出处：{{item.source}}</view>
            <view class="ai-allusion-meaning">{{item.meaning}}</view>
          </view>
        </view>
        <view class="ai-section">
          <view class="ai-section-title">情感</view>
          <view class="ai-section-text">{{AI.structured.emotion}}</view>
        </view>
        <view class="ai-section">
          <view class="ai-section-title">创作背景</view>
          <view class="ai-section-text">{{AI.structured.background}}</view>
        </view>
        <view class="ai-section" wx:if="{{AI.structured.techniques && AI.structured.techniques.length}}">
          <view class="ai-section-title">艺术手法</view>
          <view class="ai-tags">
            <text wx:for="{{AI.structured.techniques}}" wx:key="*this" class="ai-tag">{{item}}</text>
          </view>
        </view>
        <view class="ai-section">
          <view class="ai-section-title">文学史地位</view>
          <view class="ai-section-text">{{AI.structured.significance}}</view>
        </view>
      </block>
      <text wx:elif="{{AI.content}}" class="ai-raw">{{AI.content}}</text>
    </scroll-view>
  </view>
</view>

