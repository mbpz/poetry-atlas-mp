<!-- 诗词详情 — 沉浸水墨 + 竖排卷轴阅读 -->
<view wx:if="{{loading}}" class="page">
  <skeleton rows="2" />
  <skeleton rows="4" />
  <skeleton rows="2" />
</view>
<view class="page" wx:elif="{{poem}}">

  <!-- 诗词英雄卡（卷轴）-->
  <view class="poem-hero card spring-card">
    <!-- 卷轴顶部装饰 -->
    <view class="scroll-rod"></view>

    <view class="poem-title-row">
      <text class="poem-title gold-title">{{poem.title}}</text>
      <view class="fav-btn {{isFavorited ? 'on' : 'off'}}" bindtap="onToggleFavorite">{{isFavorited ? '♥' : '♡'}}</view>
    </view>
    <view class="poem-subtitle">
      <text class="dynasty-tag">{{poem.dynasty}}</text>
      <text class="poem-author-txt">{{poem.author}}</text>
    </view>

    <!-- 正文：横/竖排切换 -->
    <view class="poem-mode-toggle">
      <view class="mode-btn {{poemMode === 'v' ? 'on' : ''}}" bindtap="onTogglePoemMode" data-mode="v">竖排</view>
      <view class="mode-btn {{poemMode === 'h' ? 'on' : ''}}" bindtap="onTogglePoemMode" data-mode="h">横排</view>
    </view>

    <!-- 横排 -->
    <view wx:if="{{poemMode === 'h'}}" class="poem-content poem-text">
      <view wx:for="{{poem.lines}}" wx:key="*this" class="poem-line">{{line}}</view>
    </view>

    <!-- 竖排卷轴（右→左，左右淡出暗示可横滑）-->
    <view wx:else class="poem-scroll-wrap">
      <scroll-view scroll-x class="poem-scroll-h" enhanced show-scrollbar="{{false}}">
        <view class="poem-vertical">
          <view wx:for="{{poem.linesChars}}" wx:key="*this" class="poem-v-col">
            <text wx:for="{{item}}" wx:for-item="ch" wx:key="*this" class="poem-v-ch">{{ch}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="poem-fade-left"></view>
      <view class="poem-fade-right"></view>
    </view>

    <!-- 印章落款 -->
    <view class="poem-seal">{{poem.dynasty}}</view>
  </view>

  <!-- 朗诵入口 -->
  <view class="card recitation-card" wx:if="{{recitationCount > 0}}">
    <view class="section-title gold-title">朗诵版 · {{recitationCount}} 段</view>
    <view class="recitation-list">
      <view
        wx:for="{{recitations}}"
        wx:key="_id"
        class="recitation-item spring-btn"
        data-item="{{item}}"
        bindtap="onPlayRecitation"
      >
        <view class="recitation-play">▶</view>
        <view class="recitation-meta">
          <view class="recitation-voice">{{item.voice === 'female' ? '女声' : '男声'}}朗诵</view>
          <view class="recitation-dur">{{item.duration}}秒 · {{item.play_count}}次播放</view>
        </view>
      </view>
    </view>
  </view>
  <view class="card recitation-card empty" wx:elif="{{!loading}}">
    <view class="recitation-empty-text">朗诵版敬请期待</view>
  </view>

  <!-- 解读区：单一"注释与赏析" + AI 主入口 -->
  <view class="card interpret-card">
    <view class="section-title gold-title">注释与赏析</view>
    <view class="tab-body">
      <text wx:if="{{poem.interpretText}}" class="interpret-text">{{poem.interpretText}}</text>
      <text wx:else class="interpret-text interpret-empty">暂无人工注释，可使用 <text class="ai-link" bindtap="onAskAI">AI 深度解读</text> 了解典故、情感与背景</text>
    </view>
  </view>

  <!-- AI 主入口（hero 卡与解读区之间）-->
  <view class="ai-main-btn spring-btn" bindtap="onAskAI">
    <text class="ai-main-ico">💡</text>
    <text class="ai-main-txt">AI 深度解读</text>
    <text class="ai-main-sub">白话译文 · 典故 · 情感 · 手法</text>
  </view>

  <!-- 相关地点 -->
  <view wx:if="{{places.length}}" class="card place-card">
    <view class="section-title gold-title">相关地点</view>
    <view class="place-tags">
      <view
        wx:for="{{places}}" wx:key="name"
        class="place-tag spring-btn"
        data-place="{{item}}" bindtap="onTapPlace"
      >{{item.name}}</view>
    </view>
  </view>
</view>

<!-- ===== 底部抽屉: AI 解读面板 ===== -->
<view wx:if="{{AI.show}}" class="ai-mask" bindtap="onHideAI" catchtouchmove="onMaskTouchMove">
  <view
    class="ai-sheet {{AI.dragging ? '' : 'ai-sheet-transition'}}"
    style="height: {{AI.sheetHeight}}%;"
    catchtap
    bindtouchstart="onSheetTouchStart"
    bindtouchmove="onSheetTouchMove"
    bindtouchend="onSheetTouchEnd"
  >
    <view class="ai-sheet-handle" catchtap="onHandleTap">
      <view class="ai-sheet-bar"></view>
    </view>

    <view wx:if="{{AI.loading}}" class="ai-sheet-body">
      <view class="ai-skeleton-title"></view>
      <view class="ai-skeleton-line"></view>
      <view class="ai-skeleton-line"></view>
      <view class="ai-skeleton-line short"></view>
      <view class="ai-skeleton-title"></view>
      <view class="ai-skeleton-line"></view>
      <view class="ai-skeleton-line"></view>
    </view>

    <scroll-view wx:elif="{{AI.structured}}" scroll-y class="ai-sheet-body" enhanced show-scrollbar="{{false}}">
      <view class="ai-section">
        <view class="ai-section-title">白话译文</view>
        <view class="ai-section-text">{{AI.structured.translation}}</view>
      </view>
      <view class="ai-section" wx:if="{{AI.structured.allusions && AI.structured.allusions.length}}">
        <view class="ai-section-title">典故</view>
        <view wx:for="{{AI.structured.allusions}}" wx:key="phrase" class="ai-allusion">
          <view class="ai-allusion-phrase">{{item.phrase}}</view>
          <view class="ai-allusion-source">出处：{{item.source}}</view>
          <view class="ai-allusion-meaning">{{item.meaning}}</view>
        </view>
      </view>
      <view class="ai-section">
        <view class="ai-section-title">情感</view>
        <view class="ai-section-text">{{AI.structured.emotion}}</view>
      </view>
      <view class="ai-section">
        <view class="ai-section-title">创作背景</view>
        <view class="ai-section-text">{{AI.structured.background}}</view>
      </view>
      <view class="ai-section" wx:if="{{AI.structured.techniques && AI.structured.techniques.length}}">
        <view class="ai-section-title">艺术手法</view>
        <view class="ai-tags">
          <text wx:for="{{AI.structured.techniques}}" wx:key="*this" class="ai-tag spring-btn">{{item}}</text>
        </view>
      </view>
      <view class="ai-section">
        <view class="ai-section-title">文学史地位</view>
        <view class="ai-section-text">{{AI.structured.significance}}</view>
      </view>
    </scroll-view>

    <text wx:elif="{{AI.content}}" class="ai-sheet-body ai-raw">{{AI.content}}</text>

    <view wx:else class="ai-sheet-body ai-empty">解读失败，请重试</view>
  </view>
</view>

<!-- 朗诵播放组件（mini / 全屏） -->
<audio-player
  wx:if="{{showMiniPlayer}}"
  src="{{playerSrc}}"
  duration="{{playerDuration}}"
  lines="{{poem.lines}}"
  title="{{poem.title}}"
  author="{{poem.author}}"
  recitation-id="{{playerRecitationId}}"
  bind:play="onPlayerPlay"
  bind:close="onClosePlayer"
/>
