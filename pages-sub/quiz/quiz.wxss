/* 诗词对战 — 宣纸淡墨。颜色全部走 app.wxss CSS 变量，无硬编码。 */

.page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
}

/* ============ 开始页 ============ */
.start-screen {
  align-items: center;
  padding-top: 60rpx;
}
.start-embigger {
  font-size: 160rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}
.start-rank {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
}
.start-sub {
  color: var(--paper-text-2);
  font-size: 26rpx;
  margin-bottom: 48rpx;
  letter-spacing: 0.1em;
}
.start-stats {
  width: 100%;
  display: flex;
  align-items: stretch;
  margin-bottom: 48rpx;
}
.stat-cell {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
}
.stat-num {
  font-size: 44rpx;
  font-weight: 700;
}
.stat-label {
  font-size: 22rpx;
  color: var(--paper-text-2);
  margin-top: 8rpx;
  letter-spacing: 0.06em;
}
.stat-divider {
  width: 1rpx;
  background: var(--ink-line);
  margin: 16rpx 0;
}
.start-rules {
  text-align: center;
  margin-bottom: 56rpx;
}
.rule-tip {
  font-size: 24rpx;
  color: var(--paper-text-2);
  letter-spacing: 0.06em;
  line-height: 2;
}
.start-btn {
  width: 80%;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
}

/* ============ 答题页 ============ */
.play-screen {
  width: 100%;
}
.play-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.play-progress {
  color: var(--paper-text-2);
  font-size: 28rpx;
}
.play-index {
  color: var(--cinnabar);
  font-size: 36rpx;
  font-weight: 700;
}
.timer {
  display: flex;
  align-items: baseline;
}
.timer-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--gold);
  font-variant-numeric: tabular-nums;
}
.timer-warn {
  color: var(--cinnabar);
}
.timer-unit {
  font-size: 22rpx;
  color: var(--paper-text-2);
  margin-left: 6rpx;
}
.timer-bar {
  height: 8rpx;
  background: var(--ink-line);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}
.timer-bar-fill {
  height: 100%;
  background: var(--gold);
  border-radius: 8rpx;
  transition: width 1s linear;
}

/* 题干 */
.stem {
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}
.stem-type {
  display: inline-block;
  font-size: 22rpx;
  color: var(--cinnabar);
  border: 1rpx solid color-mix(in srgb, var(--cinnabar) 25%, transparent);
  background: color-mix(in srgb, var(--cinnabar) 8%, transparent);
  padding: 2rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 24rpx;
  letter-spacing: 0.1em;
}
.stem-line {
  font-size: 34rpx;
  line-height: 2;
  letter-spacing: 0.12em;
  color: var(--paper-text);
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.option {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}
.option-picked {
  border-color: var(--cinnabar);
  background: color-mix(in srgb, var(--cinnabar) 6%, transparent);
}
.option-label {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--ink-surface-2);
  color: var(--paper-text-2);
  font-weight: 700;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.option-picked .option-label {
  background: var(--cinnabar);
  color: #fff;
}
.option-text {
  font-size: 30rpx;
  color: var(--paper-text);
  letter-spacing: 0.06em;
}

/* 填空 */
.fill {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.fill-input {
  flex: 1;
  background: var(--ink-surface);
  border: 1rpx solid var(--ink-line);
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  letter-spacing: 0.1em;
}
.fill-submit {
  flex-shrink: 0;
  text-align: center;
  padding: 24rpx 40rpx;
}
.fill-submit.disabled {
  opacity: 0.4;
}

/* ============ 结果页 ============ */
.result-screen {
  align-items: center;
}
.rank-badge {
  width: 100%;
  text-align: center;
  padding: 48rpx 0 32rpx;
  margin-bottom: 32rpx;
}
.rank-emoji {
  font-size: 120rpx;
  line-height: 1;
}
.rank-name {
  font-size: 48rpx;
  font-weight: 700;
  margin: 16rpx 0;
  letter-spacing: 0.14em;
}
.promoted-tag {
  display: inline-block;
  font-size: 26rpx;
  color: #fff;
  background: var(--cinnabar);
  padding: 6rpx 28rpx;
  border-radius: 40rpx;
  letter-spacing: 0.1em;
}
.promoted-ok {
  background: var(--gold);
}
.promoted-fail {
  background: var(--paper-text-2);
}

.score-card {
  width: 100%;
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 48rpx;
}
.score-big {
  display: flex;
  align-items: baseline;
  justify-content: center;
}
.score-num {
  font-size: 110rpx;
  font-weight: 700;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.score-pct {
  font-size: 40rpx;
  color: var(--gold);
  margin-left: 8rpx;
}
.score-sub {
  margin-top: 16rpx;
  color: var(--paper-text-2);
  letter-spacing: 0.08em;
}

/* 解析列表 */
.review-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  align-self: flex-start;
  letter-spacing: 0.1em;
}
.review-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 48rpx;
}
.review-item {
  padding: 28rpx 32rpx;
  border-left: 6rpx solid var(--ink-line);
}
.review-correct {
  border-left-color: var(--gold);
}
.review-wrong {
  border-left-color: var(--cinnabar);
}
.review-head {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}
.review-icon {
  width: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
  color: var(--gold);
}
.review-wrong .review-icon {
  color: var(--cinnabar);
}
.review-stem {
  font-size: 28rpx;
  color: var(--paper-text);
  letter-spacing: 0.06em;
}
.review-ans {
  font-size: 26rpx;
  color: var(--paper-text-2);
  padding-left: 40rpx;
  line-height: 1.8;
}
.review-label {
  color: var(--paper-text-2);
}
.text-ok {
  color: var(--gold);
  font-weight: 600;
}
.text-fail {
  color: var(--cinnabar);
}
.review-explain {
  font-size: 24rpx;
  color: var(--paper-text-2);
  padding-left: 40rpx;
  margin-top: 8rpx;
  line-height: 1.8;
}

/* 操作 */
.result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
  padding-bottom: 40rpx;
}
.act-btn {
  width: 80%;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
}

/* ============ 单题解析浮层 ============ */
.explain-overlay {
  margin-top: 32rpx;
}
.explain-card {
  padding: 32rpx;
  text-align: center;
}
.explain-result {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.explain-mark {
  font-size: 40rpx;
}
.explain-ans {
  font-size: 28rpx;
  color: var(--paper-text);
  margin-bottom: 12rpx;
  letter-spacing: 0.06em;
}
.explain-text {
  font-size: 24rpx;
  color: var(--paper-text-2);
  line-height: 1.8;
  letter-spacing: 0.04em;
}
