/* ===== 路线创建页 ===== */
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(160rpx + env(safe-area-inset-bottom)));
  background: var(--ink-bg);
}

.form-card {
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--paper-text-2);
  margin: 16rpx 0 8rpx;
  letter-spacing: 0.06em;
}
.form-label:first-child { margin-top: 0; }

.form-input {
  height: 80rpx;
  border: 1rpx solid var(--ink-line);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--paper-text);
  background: var(--ink-bg);
  margin-bottom: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--ink-line);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--paper-text);
  background: var(--ink-bg);
  margin-bottom: 16rpx;
  line-height: 1.7;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.add-btn {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
}
.add-btn-txt { font-size: 24rpx; color: var(--cinnabar); }

.point-card {
  border: 1rpx solid var(--ink-line);
  border-radius: 12rpx;
  padding: 24rpx 24rpx 8rpx;
  margin-bottom: 20rpx;
  background: var(--ink-bg);
}

.point-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.point-num { font-size: 26rpx; color: var(--gold); font-weight: 600; letter-spacing: 0.06em; }
.point-actions { display: flex; gap: 12rpx; }
.pt-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--ink-surface-2);
  border: 1rpx solid var(--ink-line);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  color: var(--paper-text);
}
.pt-del { color: var(--cinnabar); }

.coord-row { display: flex; gap: 16rpx; }
.coord-input { flex: 1; }

.save-row {
  margin: 32rpx 0 0;
  padding-bottom: 24rpx;
}
.save-btn {
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  letter-spacing: 0.1em;
}
.save-btn.disabled { opacity: 0.5; }
