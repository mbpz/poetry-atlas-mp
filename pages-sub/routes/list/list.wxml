<!-- 我的路线列表页（私有 · 仅自己可见）-->
<view class="page">
  <view class="page-private-hint">私密内容 · 仅自己可见</view>
  <view wx:if="{{routes.length}}" class="route-list">
    <view
      wx:for="{{routes}}"
      wx:key="_id"
      class="card route-row spring-card"
      data-id="{{item._id}}"
      bindtap="onTapRoute"
      bindlongpress="onLongPressRoute"
    >
      <view class="route-row-main">
        <view class="route-name">{{item.name}}</view>
        <view wx:if="{{item.theme}}" class="route-theme">「{{item.theme}}」</view>
        <view wx:if="{{item.description}}" class="route-desc">{{item.description}}</view>
      </view>
      <view class="route-row-meta">
        <view class="route-pts">{{item.points.length}} 站</view>
        <text class="route-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && !routes.length}}" class="empty-wrap">
    <empty-state
      iconSrc="/tab-bar-icons/map.svg"
      title="还没有自建路线"
      tip="创建一条属于你的诗词之旅"
      showBtn
      btnText="立即创建"
      bind:tap="onCreateTap"
    />
  </view>

  <view wx:if="{{loading}}" class="empty-wrap">
    <view class="list-loading">载入中…</view>
  </view>
</view>
